enum AlertMetric {
  // Infrastructure (threshold-based, per-node)
  node_unreachable
  cpu_usage
  memory_usage
  disk_usage
  error_rate
  discarded_rate
  pipeline_crashed

  // Pipeline-scoped SLI metrics (threshold-based, per-pipeline aggregate)
  // Evaluated by FleetAlertService against PipelineMetric rollups.
  latency_mean
  throughput_floor

  // Fleet-wide (threshold-based, per-environment)
  fleet_error_rate
  fleet_throughput_drop
  fleet_event_volume
  node_load_imbalance

  // Drift detection (threshold-based)
  version_drift
  config_drift

  // Events (fire on occurrence)
  deploy_requested
  deploy_completed
  deploy_rejected
  deploy_cancelled
  new_version_available
  scim_sync_failed
  backup_failed
  certificate_expiring
  node_joined
  node_left
  // Phase 5 event — enum value added early so subscriptions can be created
  promotion_completed
  git_sync_failed
  cost_threshold_exceeded // fires when monthly cost exceeds costBudgetCents
  log_keyword
}

enum AlertCondition {
  gt
  lt
  eq
}

enum AlertStatus {
  firing
  resolved
  acknowledged
  dismissed
}

