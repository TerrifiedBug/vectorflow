generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                 String       @id @default(cuid())
  email              String       @unique
  name               String?
  image              String?
  passwordHash       String?
  authMethod         AuthMethod   @default(LOCAL)
  memberships        TeamMember[]
  accounts           Account[]
  lockedAt           DateTime?
  lockedBy           String?
  isSuperAdmin       Boolean      @default(false)
  mustChangePassword Boolean      @default(false)
  totpSecret         String?
  totpEnabled        Boolean      @default(false)
  totpBackupCodes    String?
  auditLogs          AuditLog[]
  pipelinesUpdated   Pipeline[]   @relation("PipelineUpdatedBy")
  vrlSnippets        VrlSnippet[]
  createdAt          DateTime     @default(now())
}

enum AuthMethod {
  LOCAL
  OIDC
}

model Team {
  id               String        @id @default(cuid())
  name             String
  requireTwoFactor Boolean       @default(false)
  members          TeamMember[]
  environments     Environment[]
  templates        Template[]
  vrlSnippets      VrlSnippet[]
  alertRules       AlertRule[]
  createdAt        DateTime      @default(now())
}

model TeamMember {
  id     String @id @default(cuid())
  userId String
  teamId String
  role   Role
  user   User   @relation(fields: [userId], references: [id])
  team   Team   @relation(fields: [teamId], references: [id])

  @@unique([userId, teamId])
}

enum Role {
  VIEWER
  EDITOR
  ADMIN
}

model Environment {
  id                  String        @id @default(cuid())
  name                String
  isSystem            Boolean       @default(false)
  teamId              String?
  team                Team?         @relation(fields: [teamId], references: [id])
  nodes               VectorNode[]
  pipelines           Pipeline[]
  secrets             Secret[]
  certificates        Certificate[]
  auditLogs           AuditLog[]
  enrollmentTokenHash String?
  enrollmentTokenHint String?
  secretBackend       SecretBackend @default(BUILTIN)
  secretBackendConfig Json?
  alertRules          AlertRule[]
  alertWebhooks       AlertWebhook[]
  createdAt           DateTime      @default(now())
}

model VectorNode {
  id               String               @id @default(cuid())
  name             String
  host             String
  apiPort          Int                  @default(8686)
  environmentId    String
  environment      Environment          @relation(fields: [environmentId], references: [id])
  status           NodeStatus           @default(UNKNOWN)
  lastSeen         DateTime?
  metadata         Json?
  nodeTokenHash    String?
  enrolledAt       DateTime?
  lastHeartbeat    DateTime?
  agentVersion     String?
  vectorVersion    String?
  os               String?
  deploymentMode   DeploymentMode       @default(UNKNOWN)
  pendingAction    Json?
  pipelineStatuses NodePipelineStatus[]
  nodeMetrics      NodeMetric[]
  pipelineLogs     PipelineLog[]
  createdAt        DateTime             @default(now())
}

model NodeMetric {
  id               String     @id @default(cuid())
  nodeId           String
  node             VectorNode @relation(fields: [nodeId], references: [id], onDelete: Cascade)
  timestamp        DateTime
  memoryTotalBytes BigInt     @default(0)
  memoryUsedBytes  BigInt     @default(0)
  memoryFreeBytes  BigInt     @default(0)
  cpuSecondsTotal  Float      @default(0)
  loadAvg1         Float      @default(0)
  loadAvg5         Float      @default(0)
  loadAvg15        Float      @default(0)
  fsTotalBytes     BigInt     @default(0)
  fsUsedBytes      BigInt     @default(0)
  fsFreeBytes      BigInt     @default(0)
  diskReadBytes    BigInt     @default(0)
  diskWrittenBytes BigInt     @default(0)
  netRxBytes       BigInt     @default(0)
  netTxBytes       BigInt     @default(0)

  @@index([nodeId, timestamp])
  @@index([timestamp])
}

enum NodeStatus {
  HEALTHY
  DEGRADED
  UNREACHABLE
  UNKNOWN
}

enum DeploymentMode {
  STANDALONE
  DOCKER
  UNKNOWN
}

enum LogLevel {
  TRACE
  DEBUG
  INFO
  WARN
  ERROR
}

model PipelineLog {
  id         String     @id @default(cuid())
  pipelineId String
  pipeline   Pipeline   @relation(fields: [pipelineId], references: [id], onDelete: Cascade)
  nodeId     String
  node       VectorNode @relation(fields: [nodeId], references: [id], onDelete: Cascade)
  timestamp  DateTime   @default(now())
  level      LogLevel   @default(INFO)
  message    String

  @@index([pipelineId, timestamp])
  @@index([nodeId, timestamp])
  @@index([timestamp])
}

enum SecretBackend {
  BUILTIN
  VAULT
  AWS_SM
  EXEC
}

enum ProcessStatus {
  RUNNING
  STARTING
  STOPPED
  CRASHED
  PENDING
}

model Pipeline {
  id            String               @id @default(cuid())
  name          String
  description   String?
  environmentId String
  environment   Environment          @relation(fields: [environmentId], references: [id])
  nodes         PipelineNode[]
  edges         PipelineEdge[]
  versions      PipelineVersion[]
  globalConfig  Json?
  isDraft       Boolean              @default(true)
  isSystem      Boolean              @default(false)
  deployedAt    DateTime?
  updatedById   String?
  updatedBy     User?                @relation("PipelineUpdatedBy", fields: [updatedById], references: [id])
  nodeStatuses  NodePipelineStatus[]
  metrics       PipelineMetric[]
  pipelineLogs    PipelineLog[]
  alertRules      AlertRule[]
  sampleRequests  EventSampleRequest[]
  eventSamples    EventSample[]
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
}

model NodePipelineStatus {
  id            String        @id @default(cuid())
  nodeId        String
  node          VectorNode    @relation(fields: [nodeId], references: [id], onDelete: Cascade)
  pipelineId    String
  pipeline      Pipeline      @relation(fields: [pipelineId], references: [id], onDelete: Cascade)
  version       Int
  status        ProcessStatus @default(PENDING)
  pid           Int?
  uptimeSeconds Int?
  eventsIn        BigInt        @default(0)
  eventsOut       BigInt        @default(0)
  errorsTotal     BigInt        @default(0)
  eventsDiscarded BigInt        @default(0)
  bytesIn         BigInt        @default(0)
  bytesOut        BigInt        @default(0)
  utilization     Float         @default(0)
  recentLogs    Json?
  lastUpdated   DateTime      @default(now())

  @@unique([nodeId, pipelineId])
}

model PipelineMetric {
  id              String   @id @default(cuid())
  pipelineId      String
  pipeline        Pipeline @relation(fields: [pipelineId], references: [id], onDelete: Cascade)
  nodeId          String?
  timestamp       DateTime
  eventsIn        BigInt   @default(0)
  eventsOut       BigInt   @default(0)
  eventsDiscarded BigInt   @default(0)
  errorsTotal     BigInt   @default(0)
  bytesIn         BigInt   @default(0)
  bytesOut        BigInt   @default(0)
  utilization     Float    @default(0)

  @@index([pipelineId, timestamp])
  @@index([timestamp])
}

model EventSampleRequest {
  id            String        @id @default(cuid())
  pipelineId    String
  pipeline      Pipeline      @relation(fields: [pipelineId], references: [id], onDelete: Cascade)
  componentKeys Json
  limit         Int           @default(5)
  status        String        @default("PENDING")
  nodeId        String?
  requestedAt   DateTime      @default(now())
  expiresAt     DateTime
  completedAt   DateTime?
  samples       EventSample[]
}

model EventSample {
  id            String              @id @default(cuid())
  requestId     String
  request       EventSampleRequest  @relation(fields: [requestId], references: [id], onDelete: Cascade)
  pipelineId    String
  pipeline      Pipeline            @relation(fields: [pipelineId], references: [id], onDelete: Cascade)
  componentKey  String
  events        Json
  schema        Json
  error         String?
  sampledAt     DateTime            @default(now())

  @@index([pipelineId, componentKey])
}

model PipelineNode {
  id            String        @id @default(cuid())
  pipelineId    String
  pipeline      Pipeline      @relation(fields: [pipelineId], references: [id], onDelete: Cascade)
  componentKey  String
  componentType String
  kind          ComponentKind
  config        Json
  positionX     Float
  positionY     Float
  disabled      Boolean       @default(false)
}

enum ComponentKind {
  SOURCE
  TRANSFORM
  SINK
}

model PipelineEdge {
  id           String   @id @default(cuid())
  pipelineId   String
  pipeline     Pipeline @relation(fields: [pipelineId], references: [id], onDelete: Cascade)
  sourceNodeId String
  targetNodeId String
  sourcePort   String?
}

model PipelineVersion {
  id          String   @id @default(cuid())
  pipelineId  String
  pipeline    Pipeline @relation(fields: [pipelineId], references: [id], onDelete: Cascade)
  version     Int
  configYaml  String
  configToml  String?
  logLevel    String?
  globalConfig Json?
  createdById String
  changelog   String?
  createdAt   DateTime @default(now())
}

model Secret {
  id             String      @id @default(cuid())
  name           String
  encryptedValue String
  environmentId  String
  environment    Environment @relation(fields: [environmentId], references: [id], onDelete: Cascade)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  @@unique([environmentId, name])
}

model Certificate {
  id            String      @id @default(cuid())
  name          String
  filename      String
  fileType      String
  encryptedData String
  environmentId String
  environment   Environment @relation(fields: [environmentId], references: [id], onDelete: Cascade)
  createdAt     DateTime    @default(now())

  @@unique([environmentId, name])
}

model Template {
  id          String   @id @default(cuid())
  name        String
  description String
  category    String
  teamId      String?
  team        Team?    @relation(fields: [teamId], references: [id])
  nodes       Json
  edges       Json
  createdAt   DateTime @default(now())
}

model AuditLog {
  id            String       @id @default(cuid())
  userId        String
  user          User         @relation(fields: [userId], references: [id])
  action        String
  entityType    String
  entityId      String
  diff          Json?
  metadata      Json?
  ipAddress     String?
  userEmail     String?
  userName      String?
  teamId        String?
  environmentId String?
  environment   Environment? @relation(fields: [environmentId], references: [id])
  createdAt     DateTime     @default(now())

  @@index([entityType, entityId])
  @@index([userId])
  @@index([createdAt])
}

model SystemSettings {
  id String @id @default("singleton")

  oidcIssuer                  String?
  oidcClientId                String?
  oidcClientSecret            String?
  oidcDisplayName             String? @default("SSO")
  oidcDefaultRole             Role    @default(VIEWER)
  oidcGroupsClaim             String? @default("groups")
  oidcAdminGroups             String? // Comma-separated group names → ADMIN role
  oidcEditorGroups            String? // Comma-separated group names → EDITOR role
  oidcTokenEndpointAuthMethod String? @default("client_secret_post")
  oidcTeamMappings            String? // JSON: [{group, teamId, role}]
  oidcDefaultTeamId           String? // Fallback team for unmatched users

  fleetPollIntervalMs     Int @default(15000)
  fleetUnhealthyThreshold Int @default(3)
  metricsRetentionDays    Int @default(7)
  logsRetentionDays       Int @default(3)

  latestServerRelease          String?
  latestServerReleaseCheckedAt DateTime?
  latestAgentRelease           String?
  latestAgentReleaseCheckedAt  DateTime?

  updatedAt DateTime @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model VrlSnippet {
  id          String   @id @default(cuid())
  teamId      String
  team        Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  name        String
  description String?
  category    String
  code        String
  createdBy   String
  creator     User     @relation(fields: [createdBy], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([teamId, name])
  @@index([teamId])
}

enum AlertMetric {
  node_unreachable
  cpu_usage
  memory_usage
  disk_usage
  error_rate
  discarded_rate
  pipeline_crashed
}

enum AlertCondition {
  gt
  lt
  eq
}

enum AlertStatus {
  firing
  resolved
}

model AlertRule {
  id              String         @id @default(cuid())
  name            String
  enabled         Boolean        @default(true)
  environmentId   String
  environment     Environment    @relation(fields: [environmentId], references: [id], onDelete: Cascade)
  pipelineId      String?
  pipeline        Pipeline?      @relation(fields: [pipelineId], references: [id], onDelete: Cascade)
  teamId          String
  team            Team           @relation(fields: [teamId], references: [id], onDelete: Cascade)
  metric          AlertMetric
  condition       AlertCondition
  threshold       Float
  durationSeconds Int            @default(60)
  events          AlertEvent[]
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@index([environmentId])
  @@index([teamId])
}

model AlertWebhook {
  id            String      @id @default(cuid())
  environmentId String
  environment   Environment @relation(fields: [environmentId], references: [id], onDelete: Cascade)
  url           String
  headers       Json?
  hmacSecret    String?
  enabled       Boolean     @default(true)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([environmentId])
}

model AlertEvent {
  id          String      @id @default(cuid())
  alertRuleId String
  alertRule   AlertRule   @relation(fields: [alertRuleId], references: [id], onDelete: Cascade)
  status      AlertStatus
  value       Float
  message     String?
  firedAt     DateTime    @default(now())
  resolvedAt  DateTime?
  notifiedAt  DateTime?

  @@index([alertRuleId])
  @@index([firedAt])
}
