generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Multi-tenancy ──────────────────────────────────────────────────────────

// Well-known ID for the single default organization (OSS / self-hosted).
// Every tenant row backfills to this ID; Cloud creates real orgs on signup.
// Keep this string in sync with DEFAULT_ORG_ID in src/lib/constants.ts.

enum OrgPlan {
  DEFAULT
  FREE
  PRO
  ENTERPRISE
}

enum OrgMemberRole {
  OWNER
  ADMIN
  MEMBER
}

enum PlatformOperatorRole {
  SUPPORT
  INFRA
  BILLING
  INCIDENT
}

model Organization {
  id                String    @id @default(cuid())
  slug              String    @unique
  name              String
  plan              OrgPlan   @default(DEFAULT)
  region            String    @default("default")
  // Envelope-encryption fields — null for OSS / self-hosted
  dataKeyCiphertext String?
  kmsKeyArn         String?
  byokKeyArn        String?
  // Lifecycle
  suspendedAt       DateTime?
  deletedAt         DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  members              OrgMember[]
  settings             OrganizationSettings?
  accessGrants         OrgAccessGrant[]
  magicLinkTokens      MagicLinkToken[]
  webhookConfirmations WebhookConfirmation[]
  billingProviderRefs  BillingProviderRef[]
}

model OrgMember {
  id             String        @id @default(cuid())
  userId         String
  organizationId String
  role           OrgMemberRole @default(MEMBER)
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization   Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt      DateTime      @default(now())

  @@unique([userId, organizationId])
  @@index([userId])
  @@index([organizationId])
}

model OrganizationSettings {
  id             String       @id @default(cuid())
  organizationId String       @unique
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  // OIDC SSO (moved from SystemSettings singleton)
  oidcIssuer                  String?
  oidcClientId                String?
  oidcClientSecret            String?
  oidcDisplayName             String? @default("SSO")
  oidcDefaultRole             Role    @default(VIEWER)
  oidcGroupSyncEnabled        Boolean @default(false)
  oidcGroupsScope             String? @default("groups")
  oidcGroupsClaim             String? @default("groups")
  oidcAdminGroups             String?
  oidcEditorGroups            String?
  oidcTokenEndpointAuthMethod String? @default("client_secret_post")
  oidcTeamMappings            String?
  oidcDefaultTeamId           String?

  // Fleet tuning (moved from SystemSettings)
  fleetPollIntervalMs     Int @default(15000)
  fleetUnhealthyThreshold Int @default(3)
  metricsRetentionDays    Int @default(7)
  logsRetentionDays       Int @default(3)

  // Anomaly detection tuning (moved from SystemSettings)
  anomalyBaselineWindowDays    Int    @default(7)
  anomalySigmaThreshold        Float  @default(3)
  anomalyMinStddevFloorPercent Int    @default(5)
  anomalyDedupWindowHours      Int    @default(4)
  anomalyEnabledMetrics        String @default("eventsIn,errorsTotal,latencyMeanMs")

  // Backup configuration (moved from SystemSettings)
  backupEnabled        Boolean   @default(false)
  backupCron           String    @default("0 2 * * *")
  backupRetentionCount Int       @default(7)
  lastBackupAt         DateTime?
  lastBackupStatus     String?
  lastBackupError      String?

  // S3 remote storage (moved from SystemSettings)
  backupStorageBackend String  @default("local")
  s3Bucket             String?
  s3Region             String? @default("us-east-1")
  s3Prefix             String?
  s3AccessKeyId        String?
  s3SecretAccessKey    String?
  s3Endpoint           String?

  // SCIM (moved from SystemSettings)
  scimEnabled     Boolean @default(false)
  scimBearerToken String?

  // Telemetry (moved from SystemSettings)
  telemetryEnabled    Boolean   @default(false)
  telemetryInstanceId String?
  telemetryEnabledAt  DateTime?

  // Phase 5z: explicit opt-in for non-allowlisted AI provider baseUrls.
  // When false (default) AI calls MUST target a host in `AI_PROVIDER_ALLOWLIST`
  // (api.openai.com, api.anthropic.com). When true, an org OWNER can set a
  // custom `Team.aiBaseUrl` after passing `validateOutboundUrl` strict mode.
  aiBaseUrlOptIn Boolean @default(false)

  updatedAt DateTime @updatedAt
}

/// Break-glass access grant. Operator can read encrypted fields only while
/// this record is active and the customer OWNER has approved it.
model OrgAccessGrant {
  id                        String           @id @default(cuid())
  organizationId            String
  organization              Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  operatorId                String
  operator                  PlatformOperator @relation(fields: [operatorId], references: [id], onDelete: Cascade)
  reason                    String
  approvedByCustomerAdminId String?
  kmsGrantToken             String?
  expiresAt                 DateTime
  revokedAt                 DateTime?
  createdAt                 DateTime         @default(now())

  @@index([organizationId])
  @@index([operatorId])
  @@index([expiresAt])
}

/// Platform operator — never a tenant User. Authenticates via separate surface.
model PlatformOperator {
  id        String               @id @default(cuid())
  email     String               @unique
  name      String
  role      PlatformOperatorRole @default(SUPPORT)
  createdAt DateTime             @default(now())
  updatedAt DateTime             @updatedAt

  accessGrants OrgAccessGrant[]
}

// ─── End multi-tenancy models ───────────────────────────────────────────────
model User {
  id                       String               @id @default(cuid())
  email                    String               @unique
  name                     String?
  image                    String?
  passwordHash             String?
  authMethod               AuthMethod           @default(LOCAL)
  memberships              TeamMember[]
  orgMemberships           OrgMember[]
  scimGroupMemberships     ScimGroupMember[]
  accounts                 Account[]
  lockedAt                 DateTime?
  lockedBy                 String?
  isSuperAdmin             Boolean              @default(false)
  mustChangePassword       Boolean              @default(false)
  totpSecret               String?
  totpEnabled              Boolean              @default(false)
  totpBackupCodes          String?
  scimExternalId           String?              @unique
  auditLogs                AuditLog[]
  pipelinesUpdated         Pipeline[]           @relation("PipelineUpdatedBy")
  pipelinesCreated         Pipeline[]           @relation("PipelineCreatedBy")
  vrlSnippets              VrlSnippet[]
  dashboardViews           DashboardView[]
  serviceAccounts          ServiceAccount[]
  deployRequestsMade       DeployRequest[]      @relation("deployRequester")
  deployRequestsReviewed   DeployRequest[]      @relation("deployReviewer")
  deployRequestsExecuted   DeployRequest[]      @relation("deployExecutor")
  promotionRequests        PromotionRequest[]   @relation("PromotionRequester")
  promotionApprovals       PromotionRequest[]   @relation("PromotionApprover")
  preferences              UserPreference[]
  aiConversationsCreated   AiConversation[]     @relation("AiConversationCreatedBy")
  aiMessagesCreated        AiMessage[]          @relation("AiMessageCreatedBy")
  pipelineVersionsCreated  PipelineVersion[]    @relation("PipelineVersionCreatedBy")
  stagedRolloutsCreated    StagedRollout[]      @relation("StagedRolloutCreatedBy")
  filterPresets            FilterPreset[]
  migrationProjectsCreated MigrationProject[]   @relation("MigrationProjectCreatedBy")
  dismissedRecommendations CostRecommendation[] @relation("CostRecommendationDismissedBy")
  webauthnCredentials      WebAuthnCredential[]
  createdAt                DateTime             @default(now())
}

/// WebAuthn / passkey credential registered for a User (plan §8 Phase 5x).
///
/// Cross-org users carry one credential set per `User` — passkeys are
/// account-wide, not per-tenant. The relying-party identity is the platform
/// apex (`vectorflow.sh`) so a single passkey works across every
/// `<orgSlug>.vectorflow.sh` the user is a member of. Per-org JWT
/// signing keys (plan §8) still scope the resulting session to one org.
model WebAuthnCredential {
  id           String    @id @default(cuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// Base64url-encoded credential id returned by the authenticator. Unique
  /// across the whole platform so we can resolve a user from a bare
  /// `getAssertion()` response without first looking up the email.
  credentialId String    @unique
  /// Raw COSE-encoded public key bytes (Bytes, not bytea-encoded base64).
  publicKey    Bytes
  /// Authenticator signature counter. MUST be persisted and re-checked on
  /// every assertion to defeat token cloning / replay.
  counter      BigInt    @default(0)
  /// Transport hints (`usb`, `ble`, `nfc`, `internal`, `hybrid`). Stored so
  /// `allowCredentials` on subsequent authentications can include them
  /// without re-prompting the user.
  transports   String[]  @default([])
  /// `"singleDevice"` (hardware token tied to one device) or
  /// `"multiDevice"` (passkey synced via the platform — iCloud Keychain etc.).
  deviceType   String?
  /// True when the credential is backed up by the platform (synced).
  backedUp     Boolean   @default(false)
  /// User-supplied label, e.g. "YubiKey 5C" or "MacBook TouchID".
  name         String?
  createdAt    DateTime  @default(now())
  lastUsedAt   DateTime?

  @@index([userId])
}

/// Short-lived WebAuthn challenge issued during register / authenticate
/// option-generation. Stored in the DB (not a cookie) so the verifying
/// request can prove the challenge it received was the one we minted.
/// Rows MUST be expired aggressively — default 5 minutes is more than
/// enough for the platform/authenticator round trip.
model WebAuthnChallenge {
  id        String   @id @default(cuid())
  /// One of "register" or "authenticate".
  kind      String
  /// The challenge bytes, base64url-encoded.
  challenge String   @unique
  /// Userid the challenge was minted for. Nullable because the
  /// authentication flow may begin without a known user (usernameless
  /// passkey UX).
  userId    String?
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([expiresAt])
  @@index([userId])
}

/// Magic-link sign-in token (plan §8 Phase 5y).
///
/// Cloud-default authentication for new orgs is "SSO or magic link". This
/// table is the persistent state for the magic-link flow: a hash of the
/// random token is stored, the email it was minted for, the org it
/// belongs to (so per-org rate limiting can decide what to allow), and a
/// short TTL. Single-use: `consumedAt` is set inside the verifying
/// transaction so a captured link cannot be redeemed twice.
///
/// The plaintext token is NEVER stored — only `tokenHash` (SHA-256 hex).
/// The plaintext is mailed to the user once; the verify endpoint hashes
/// the incoming token and compares against `tokenHash`.
model MagicLinkToken {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  /// Email address the link was minted for. Used to resolve the User on
  /// redeem (or to bootstrap a new User on first sign-in).
  email          String
  /// SHA-256 hex digest of the plaintext token. Plaintext is NEVER stored.
  tokenHash      String       @unique
  expiresAt      DateTime
  consumedAt     DateTime?
  /// IP that requested the link, for audit.
  requestIp      String?
  createdAt      DateTime     @default(now())

  @@index([organizationId, email])
  @@index([expiresAt])
}

/// `BillingProviderRef` is the OSS-side mapping between an `Organization`
/// and an external billing provider's customer / subscription IDs. Generic
/// on purpose (per §15a R1 / R3 rationale: keep generic patterns in OSS,
/// keep provider-specific code in the closed surface).
///
/// The Cloud build's Stripe webhook handler upserts a row on
/// `customer.subscription.created` / `.updated` with `provider="stripe"`.
/// The nightly metering aggregator reads `providerSubscriptionItemId` to
/// post usage records back. Self-hosted OSS installs leave this table
/// empty; the engine is dormant when no rows exist.
///
/// The pattern is reusable for any provider that emits a stable
/// `(customerId, subscriptionItemId)` pair — Paddle, LemonSqueezy,
/// Chargebee, etc. None of those provider names appear in OSS code; the
/// `provider` field is a free-form string and the Cloud overlay decides
/// what providers are recognized.
model BillingProviderRef {
  id                         String       @id @default(cuid())
  organizationId             String
  organization               Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  /// Free-form provider identifier. Cloud convention: lowercase, e.g.
  /// "stripe", "paddle". OSS imposes no constraint.
  provider                   String
  /// External provider's stable customer id (e.g. Stripe `cus_…`).
  providerCustomerId         String
  /// External provider's subscription-item id used as the metering target
  /// (e.g. Stripe `si_…`). Optional because per-seat-only plans don't
  /// have a metered subscription item.
  providerSubscriptionItemId String?
  /// Free-form status string set by the provider's webhook (e.g.
  /// "active", "past_due", "canceled"). Engine treats only "active" as
  /// billable; everything else is a skip for metering.
  status                     String       @default("active")
  createdAt                  DateTime     @default(now())
  updatedAt                  DateTime     @updatedAt

  /// One row per (org, provider). Re-subscribing replaces the row via
  /// upsert; we don't keep history here (the provider has audit logs).
  @@unique([provider, organizationId])
  /// Reverse lookup by external customer id is the inbound-webhook path.
  @@unique([provider, providerCustomerId])
  @@index([organizationId])
}

model UserPreference {
  id             String @id @default(cuid())
  organizationId String @default("default")
  userId         String
  user           User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  key            String
  value          String

  @@unique([userId, key])
  @@index([userId])
  @@index([organizationId])
}

enum AuthMethod {
  LOCAL
  OIDC
}

model Team {
  id                   String             @id @default(cuid())
  organizationId       String             @default("default")
  name                 String
  requireTwoFactor     Boolean            @default(false)
  defaultEnvironmentId String?
  defaultEnvironment   Environment?       @relation("teamDefault", fields: [defaultEnvironmentId], references: [id], onDelete: SetNull)
  members              TeamMember[]
  environments         Environment[]
  templates            Template[]
  vrlSnippets          VrlSnippet[]
  alertRules           AlertRule[]
  availableTags        Json?              @default("[]") // string[] of admin-defined compliance tags
  webhookEndpoints     WebhookEndpoint[]
  migrationProjects    MigrationProject[]

  // AI-powered suggestions configuration
  aiProvider String? // "openai" | "anthropic" | "custom"
  aiBaseUrl  String? // OpenAI-compatible API endpoint
  aiApiKey   String? // Encrypted via crypto.ts
  aiModel    String? // e.g. "gpt-4o", "claude-sonnet-4-20250514"
  aiEnabled  Boolean @default(false)

  costRecommendations CostRecommendation[]
  anomalyEvents       AnomalyEvent[]
  createdAt           DateTime             @default(now())

  @@index([organizationId])
}

model ScimGroup {
  id          String            @id @default(cuid())
  displayName String            @unique
  externalId  String?           @unique
  members     ScimGroupMember[]
  createdAt   DateTime          @default(now())
}

model ScimGroupMember {
  id          String    @id @default(cuid())
  scimGroupId String
  userId      String
  scimGroup   ScimGroup @relation(fields: [scimGroupId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())

  @@unique([scimGroupId, userId])
}

model TeamMember {
  id     String @id @default(cuid())
  userId String
  teamId String
  role   Role
  source String @default("manual")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  team   Team   @relation(fields: [teamId], references: [id])

  @@unique([userId, teamId])
}

enum Role {
  VIEWER
  EDITOR
  ADMIN
}

model Environment {
  id                    String                  @id @default(cuid())
  organizationId        String                  @default("default")
  name                  String
  isSystem              Boolean                 @default(false)
  teamId                String?
  team                  Team?                   @relation(fields: [teamId], references: [id])
  nodes                 VectorNode[]
  pipelines             Pipeline[]
  secrets               Secret[]
  certificates          Certificate[]
  certificateBundles    CertificateBundle[]
  auditLogs             AuditLog[]
  enrollmentTokenHash   String?
  enrollmentTokenHint   String?
  secretBackend         SecretBackend           @default(BUILTIN)
  secretBackendConfig   Json?
  gitRepoUrl            String?
  gitBranch             String?                 @default("main")
  gitToken              String? // Stored encrypted via crypto.ts
  gitOpsMode            String                  @default("off") // "off" | "push" | "bidirectional" | "promotion"
  gitProvider           String? // "github" | "gitlab" | "bitbucket" — auto-detected from gitRepoUrl if null
  gitWebhookSecret      String? // HMAC secret for validating incoming git webhooks
  requireDeployApproval Boolean                 @default(false)
  alertRules            AlertRule[]
  notificationChannels  NotificationChannel[]
  serviceAccounts       ServiceAccount[]
  deployRequests        DeployRequest[]
  teamDefaults          Team[]                  @relation("teamDefault")
  sharedComponents      SharedComponent[]
  pipelineGroups        PipelineGroup[]
  nodeGroups            NodeGroup[]
  stagedRollouts        StagedRollout[]
  promotionSources      PromotionRequest[]      @relation("PromotionSourceEnv")
  promotionTargets      PromotionRequest[]      @relation("PromotionTargetEnv")
  filterPresets         FilterPreset[]
  gitSyncJobs           GitSyncJob[]
  costPerGbCents        Int                     @default(0) // cents per GB processed (0 = volume-only)
  costBudgetCents       Int? // monthly budget in cents (null = no budget)
  costRecommendations   CostRecommendation[]
  anomalyEvents         AnomalyEvent[]
  correlationGroups     AlertCorrelationGroup[]
  variables             Variable[]
  createdAt             DateTime                @default(now())

  @@index([organizationId])
}

model Variable {
  id            String      @id @default(cuid())
  name          String
  value         String
  description   String?
  environmentId String
  environment   Environment @relation(fields: [environmentId], references: [id], onDelete: Cascade)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@unique([environmentId, name])
  @@index([environmentId])
}

model VectorNode {
  id                String               @id @default(cuid())
  organizationId    String               @default("default")
  name              String
  host              String
  apiPort           Int                  @default(8686)
  environmentId     String
  environment       Environment          @relation(fields: [environmentId], references: [id])
  status            NodeStatus           @default(UNKNOWN)
  lastSeen          DateTime?
  metadata          Json?
  nodeTokenHash     String?
  nodeTokenId       String?              @unique
  enrolledAt        DateTime?
  lastHeartbeat     DateTime?
  agentVersion      String?
  vectorVersion     String?
  os                String?
  runningUser       String?
  deploymentMode    DeploymentMode       @default(UNKNOWN)
  pendingAction     Json?
  lastUpdateError   String?
  maintenanceMode   Boolean              @default(false)
  maintenanceModeAt DateTime?
  labels            Json?                @default("{}")
  pipelineStatuses  NodePipelineStatus[]
  nodeMetrics       NodeMetric[]
  pipelineLogs      PipelineLog[]
  alertEvents       AlertEvent[]
  statusEvents      NodeStatusEvent[]
  createdAt         DateTime             @default(now())

  @@index([organizationId])
}

model NodeMetric {
  id               String     @id @default(cuid())
  organizationId   String     @default("default")
  nodeId           String
  node             VectorNode @relation(fields: [nodeId], references: [id], onDelete: Cascade)
  timestamp        DateTime
  memoryTotalBytes BigInt     @default(0)
  memoryUsedBytes  BigInt     @default(0)
  memoryFreeBytes  BigInt     @default(0)
  cpuSecondsTotal  Float      @default(0)
  cpuSecondsIdle   Float      @default(0)
  loadAvg1         Float      @default(0)
  loadAvg5         Float      @default(0)
  loadAvg15        Float      @default(0)
  fsTotalBytes     BigInt     @default(0)
  fsUsedBytes      BigInt     @default(0)
  fsFreeBytes      BigInt     @default(0)
  diskReadBytes    BigInt     @default(0)
  diskWrittenBytes BigInt     @default(0)
  netRxBytes       BigInt     @default(0)
  netTxBytes       BigInt     @default(0)

  @@index([nodeId, timestamp])
  @@index([timestamp])
  @@index([organizationId])
}

model NodeStatusEvent {
  id         String     @id @default(cuid())
  nodeId     String
  node       VectorNode @relation(fields: [nodeId], references: [id], onDelete: Cascade)
  fromStatus String? // null on first event (node enrolled)
  toStatus   String // HEALTHY, DEGRADED, UNREACHABLE
  reason     String? // e.g. "heartbeat timeout", "heartbeat received", "enrolled"
  timestamp  DateTime   @default(now())

  @@index([nodeId, timestamp])
  @@index([timestamp])
}

enum NodeStatus {
  HEALTHY
  DEGRADED
  UNREACHABLE
  UNKNOWN
}

enum DeploymentMode {
  STANDALONE
  DOCKER
  UNKNOWN
}

enum LogLevel {
  TRACE
  DEBUG
  INFO
  WARN
  ERROR
}

model PipelineLog {
  id             String     @id @default(cuid())
  organizationId String     @default("default")
  pipelineId     String
  pipeline       Pipeline   @relation(fields: [pipelineId], references: [id], onDelete: Cascade)
  nodeId         String
  node           VectorNode @relation(fields: [nodeId], references: [id], onDelete: Cascade)
  timestamp      DateTime   @default(now())
  level          LogLevel   @default(INFO)
  message        String

  @@index([pipelineId, timestamp])
  @@index([nodeId, timestamp])
  @@index([timestamp])
  @@index([organizationId])
}

enum SecretBackend {
  BUILTIN
  VAULT
  AWS_SM
  EXEC
}

enum ProcessStatus {
  RUNNING
  STARTING
  STOPPED
  CRASHED
  PENDING
}

model PipelineGroup {
  id            String          @id @default(cuid())
  name          String
  color         String?
  environmentId String
  environment   Environment     @relation(fields: [environmentId], references: [id])
  parentId      String?
  parent        PipelineGroup?  @relation("GroupChildren", fields: [parentId], references: [id], onDelete: SetNull)
  children      PipelineGroup[] @relation("GroupChildren")
  pipelines     Pipeline[]
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@index([environmentId])
  @@index([parentId])
}

model NodeGroup {
  id             String      @id @default(cuid())
  name           String
  environmentId  String
  environment    Environment @relation(fields: [environmentId], references: [id])
  criteria       Json        @default("{}")
  labelTemplate  Json        @default("{}")
  requiredLabels Json        @default("[]")
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  @@unique([environmentId, name])
  @@index([environmentId])
}

model Pipeline {
  id                        String               @id @default(cuid())
  organizationId            String               @default("default")
  name                      String
  description               String?
  environmentId             String
  environment               Environment          @relation(fields: [environmentId], references: [id])
  groupId                   String?
  group                     PipelineGroup?       @relation(fields: [groupId], references: [id], onDelete: SetNull)
  nodes                     PipelineNode[]
  edges                     PipelineEdge[]
  versions                  PipelineVersion[]
  globalConfig              Json?
  nodeSelector              Json?
  gitPath                   String? // Stable git file path, e.g. "production/my-pipeline.yaml"
  isDraft                   Boolean              @default(true)
  isSystem                  Boolean              @default(false)
  deployedAt                DateTime?
  createdById               String?
  createdBy                 User?                @relation("PipelineCreatedBy", fields: [createdById], references: [id])
  updatedById               String?
  updatedBy                 User?                @relation("PipelineUpdatedBy", fields: [updatedById], references: [id])
  nodeStatuses              NodePipelineStatus[]
  metrics                   PipelineMetric[]
  pipelineLogs              PipelineLog[]
  alertRules                AlertRule[]
  sampleRequests            EventSampleRequest[]
  eventSamples              EventSample[]
  slis                      PipelineSli[]
  enrichMetadata            Boolean              @default(false)
  tags                      Json?                @default("[]") // string[] of compliance tags like ["PII", "PCI-DSS"]
  autoRollbackEnabled       Boolean              @default(false)
  autoRollbackThreshold     Float                @default(5.0)
  autoRollbackWindowMinutes Int                  @default(5)
  deploymentStrategy        Json? // DeploymentStrategy | null (null = direct deploy)
  variables                 Json? // Record<string, string> — pipeline-scoped variable key-value pairs
  aiConversations           AiConversation[]
  deployRequests            DeployRequest[]
  stagedRollouts            StagedRollout[]
  upstreamDeps              PipelineDependency[] @relation("PipelineDownstream")
  downstreamDeps            PipelineDependency[] @relation("PipelineUpstream")
  promotionSources          PromotionRequest[]   @relation("PromotionSource")
  promotionTargets          PromotionRequest[]   @relation("PromotionTarget")
  gitSyncJobs               GitSyncJob[]
  migrationProject          MigrationProject?
  costRecommendations       CostRecommendation[]
  anomalyEvents             AnomalyEvent[]
  createdAt                 DateTime             @default(now())
  updatedAt                 DateTime             @updatedAt

  @@index([organizationId])
}

model PipelineDependency {
  id           String   @id @default(cuid())
  upstreamId   String
  upstream     Pipeline @relation("PipelineUpstream", fields: [upstreamId], references: [id], onDelete: Cascade)
  downstreamId String
  downstream   Pipeline @relation("PipelineDownstream", fields: [downstreamId], references: [id], onDelete: Cascade)
  description  String?
  createdAt    DateTime @default(now())

  @@unique([upstreamId, downstreamId])
  @@index([upstreamId])
  @@index([downstreamId])
}

model NodePipelineStatus {
  id              String        @id @default(cuid())
  nodeId          String
  node            VectorNode    @relation(fields: [nodeId], references: [id], onDelete: Cascade)
  pipelineId      String
  pipeline        Pipeline      @relation(fields: [pipelineId], references: [id], onDelete: Cascade)
  version         Int
  status          ProcessStatus @default(PENDING)
  pid             Int?
  uptimeSeconds   Int?
  eventsIn        BigInt        @default(0)
  eventsOut       BigInt        @default(0)
  errorsTotal     BigInt        @default(0)
  eventsDiscarded BigInt        @default(0)
  bytesIn         BigInt        @default(0)
