generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Multi-tenancy ──────────────────────────────────────────────────────────

// Well-known ID for the single default organization on a single-tenant
// deployment. Every tenant row backfills to this ID; multi-tenant
// deployments create real orgs on signup.
// Keep this string in sync with DEFAULT_ORG_ID in src/lib/constants.ts.

enum OrgPlan {
  DEFAULT
  FREE
  PRO
  ENTERPRISE
}

enum OrgMemberRole {
  OWNER
  ADMIN
  MEMBER
}

/// How an OrgMember row was created — identity provenance that keeps
/// SCIM/OIDC-provisioned members and locally-created members (signup, invite,
/// the founding OWNER) from clobbering each other. SCIM deprovisioning only
/// removes SCIM-managed memberships; LOCAL members are out of the IdP's purview.
enum OrgMemberProvenance {
  LOCAL
  SCIM
  OIDC
}

enum PlatformOperatorRole {
  SUPPORT
  INFRA
  BILLING
  INCIDENT
}

model Organization {
  id                String    @id @default(cuid())
  slug              String    @unique
  name              String
  plan              OrgPlan   @default(DEFAULT)
  deploymentLabel   String    @default("default")
  // Envelope-encryption fields — null for OSS / self-hosted
  dataKeyCiphertext String?
  dekWrapKeyId      String?
  byokWrapKeyId     String?
  // Lifecycle
  suspendedAt       DateTime?
  deletedAt         DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  /// Click-through terms acceptance. When non-null, the org's signup
  /// flow captured an explicit acceptance of the operator-published
  /// terms / privacy / acceptable-use policy. `acceptedTermsVersion`
  /// records WHICH version was accepted (so a forced re-acceptance
  /// on terms revision can be implemented by comparing this against
  /// the operator's current published version). Both are NULL for
  /// single-tenant deployments that bypass click-through.
  acceptedTermsAt       DateTime?
  acceptedTermsVersion  String?
  /// Incremented to revoke every active session for this org. Mixed
  /// into the HKDF `info` of `deriveJwtSigningKey` so the resulting
  /// signing key changes when the counter changes. Owner-triggered
  /// "revoke all sessions" bumps this; the per-org NextAuth instance
  /// cache is invalidated so subsequent requests build a fresh
  /// instance with the new derived secret.
  jwtKeyRotationCounter Int       @default(0)

  members              OrgMember[]
  settings             OrganizationSettings?
  accessGrants         OrgAccessGrant[]
  magicLinkTokens      MagicLinkToken[]
  webhookConfirmations WebhookConfirmation[]
  billingProviderRefs  BillingProviderRef[]
  operatorApprovals    OperatorApprovalRequest[]
  domainClaims         OrganizationDomainClaim[]
  scimGroups           ScimGroup[]
}

model OrgMember {
  id             String              @id @default(cuid())
  userId         String
  organizationId String
  role           OrgMemberRole       @default(MEMBER)
  /// Identity provenance for SCIM/local coexistence guards (see
  /// OrgMemberProvenance). Defaults to LOCAL so existing rows and every
  /// non-SCIM creator (signup, invite, first-run setup) are treated as local
  /// and protected from SCIM deprovisioning. scimCreateUser sets SCIM.
  provisionedVia OrgMemberProvenance @default(LOCAL)
  user           User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization   Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt      DateTime            @default(now())

  @@unique([userId, organizationId])
  @@index([userId])
  @@index([organizationId])
}

model OrganizationSettings {
  id             String       @id @default(cuid())
  organizationId String       @unique
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  // OIDC SSO (moved from SystemSettings singleton)
  oidcIssuer                  String?
  oidcClientId                String?
  oidcClientSecret            String?
  oidcDisplayName             String? @default("SSO")
  oidcDefaultRole             Role    @default(VIEWER)
  oidcGroupSyncEnabled        Boolean @default(false)
  oidcGroupsScope             String? @default("groups")
  oidcGroupsClaim             String? @default("groups")
  oidcAdminGroups             String?
  oidcEditorGroups            String?
  oidcTokenEndpointAuthMethod String? @default("client_secret_post")
  oidcTeamMappings            String?
  oidcDefaultTeamId           String?

  // Fleet tuning (moved from SystemSettings)
  fleetPollIntervalMs        Int @default(15000)
  fleetUnhealthyThreshold    Int @default(3)
  metricsRetentionDays       Int @default(7)
  metricsRollupRetentionDays Int @default(90)
  logsRetentionDays          Int @default(3)

  // Anomaly detection tuning (moved from SystemSettings)
  anomalyBaselineWindowDays    Int    @default(7)
  anomalySigmaThreshold        Float  @default(3)
  anomalyMinStddevFloorPercent Int    @default(5)
  anomalyDedupWindowHours      Int    @default(4)
  anomalyEnabledMetrics        String @default("eventsIn,errorsTotal,latencyMeanMs")

  // Backup configuration (moved from SystemSettings)
  backupEnabled        Boolean   @default(false)
  backupCron           String    @default("0 2 * * *")
  backupRetentionCount Int       @default(7)
  lastBackupAt         DateTime?
  lastBackupStatus     String?
  lastBackupError      String?

  // S3 remote storage (moved from SystemSettings)
  backupStorageBackend String  @default("local")
  s3Bucket             String?
  s3Region             String? @default("us-east-1")
  s3Prefix             String?
  s3AccessKeyId        String?
  s3SecretAccessKey    String?
  s3Endpoint           String?

  // SCIM (moved from SystemSettings)
  scimEnabled     Boolean @default(false)
  scimBearerToken String?

  // Telemetry (moved from SystemSettings)
  telemetryEnabled    Boolean   @default(false)
  telemetryInstanceId String?
  telemetryEnabledAt  DateTime?

  // Explicit opt-in for non-allowlisted AI provider baseUrls.
  // When false (default) AI calls MUST target a host in `AI_PROVIDER_ALLOWLIST`
  // (api.openai.com, api.anthropic.com). When true, an org OWNER can set a
  // custom `Team.aiBaseUrl` after passing `validateOutboundUrl` strict mode.
  aiBaseUrlOptIn Boolean @default(false)

  /// Address that receives sub-processor change notices for this organization.
  ///
  /// When NULL, the organization has not subscribed to sub-processor change
  /// notices and the operator's notice-dispatch job MUST skip the row. When
  /// set, the address receives every notice the operator dispatches; the
  /// transport (SMTP, marketing-platform, etc.) lives behind the operator
  /// surface and is not modelled in this OSS schema.
  ///
  /// Customers manage this through the settings router (`settings.update`).
  subprocessorNoticeEmail String?

  /// Operator-only escape hatch for the C.4 OIDC issuer DNS gate.
  ///
  /// When FALSE (default) `settings.updateOidc` refuses any issuer
  /// whose hostname is not covered by a verified
  /// `OrganizationDomainClaim`. When TRUE the gate accepts any
  /// parseable issuer URL — the organization can point its IdP at a
  /// shared third-party host (e.g. `accounts.google.com`,
  /// `login.microsoftonline.com/<tenant>/v2.0`, `<workspace>.okta.com`)
  /// that no single tenant can claim under the DNS-TXT primitive.
  ///
  /// **Operator-controlled.** Customers cannot self-toggle this flag.
  /// The platform flips it via an `OperatorApprovalRequest` two-person
  /// rule after a support ticket; the customer-facing settings
  /// surface exposes the value read-only. See PR #377 for the
  /// rationale: a self-serve toggle would re-introduce the C.4 attack
  /// the gate closed (admin pointing IdP at attacker-controlled host).
  allowSharedIdpHostnames Boolean @default(false)

  updatedAt DateTime @updatedAt
}

/// DNS-TXT verified domain claimed by an Organization.
///
/// Lets an org prove control of a DNS domain so the platform can drive
/// downstream policies — auto-routing OIDC sign-ins for that domain to
/// the org's IdP, allow-listing email domains for invite-less joining,
/// or restricting magic-link minting to email addresses under the
/// verified domain. Verification happens by:
///
///   1. `claimDomain({ domain })` mints a unique `verificationToken`
///      and returns the TXT record the customer must publish:
///        `_vectorflow.<domain>  IN  TXT  "vf-verify=<verificationToken>"`
///   2. The customer publishes the record on their authoritative DNS.
///   3. `verifyDomain({ id })` performs the lookup. On match, sets
///      `verifiedAt` and the claim becomes load-bearing.
///
/// Claims do not auto-expire; verified claims can be re-verified at
/// any time. Unique on `(organizationId, domain)`; a separate global
/// invariant — no two orgs may hold a verified claim on the same
/// domain — is enforced atomically by the partial unique index
/// `OrganizationDomainClaim_domain_verified_unique` created in migration
/// `20260519000003_organization_domain_claim`. Prisma's schema language
/// does not express conditional unique indexes at this version, so the
/// constraint lives in raw SQL; the router's `verifyDomain` handler
/// catches P2002 and surfaces a CONFLICT TRPCError.
model OrganizationDomainClaim {
  id                String       @id @default(cuid())
  organizationId    String
  organization      Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  /// Lowercase, punycoded ASCII domain. Stored without scheme, port,
  /// or trailing dot.
  domain            String
  /// Random base32 token published in the `_vectorflow.<domain>` TXT
  /// record as `vf-verify=<verificationToken>`. Unguessable so a rival
  /// cannot guess the value and publish it on a domain they control to
  /// grief the legitimate owner. Rotated on re-claim.
  verificationToken String       @unique
  /// Timestamp of the most recent successful DNS-TXT lookup. NULL =
  /// unverified.
  verifiedAt        DateTime?
  /// Most recent verification attempt timestamp (success or failure).
  /// Used to rate-limit DNS lookups from the verify endpoint.
  lastCheckedAt     DateTime?
  /// Free-text reason from the resolver when the most recent check
  /// failed (e.g. "NXDOMAIN", "no TXT records", "value mismatch"). NULL
  /// when no check has run or the last check succeeded.
  lastCheckError    String?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  @@unique([organizationId, domain])
  // @@index below covers equality probes on `domain` for the soft pre-check
  // in `verifyDomain`. The load-bearing cross-org uniqueness guard is the
  // partial unique index `OrganizationDomainClaim_domain_verified_unique`
  // (WHERE "verifiedAt" IS NOT NULL) defined in raw SQL in migration
  // 20260519000003_organization_domain_claim — Prisma cannot express it.
  @@index([domain])
  @@index([organizationId])
}

/// Break-glass access grant. Operator can read encrypted fields only while
/// this record is active and the customer OWNER has approved it.
model OrgAccessGrant {
  id                        String           @id @default(cuid())
  organizationId            String
  organization              Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  operatorId                String
  operator                  PlatformOperator @relation(fields: [operatorId], references: [id], onDelete: Cascade)
  reason                    String
  approvedByCustomerAdminId String?
  externalGrantRef          String?
  expiresAt                 DateTime
  revokedAt                 DateTime?
  createdAt                 DateTime         @default(now())

  @@index([organizationId])
  @@index([operatorId])
  @@index([expiresAt])
}

/// Platform operator — never a tenant User. Authenticates via separate surface.
///
/// Operators are **soft-deleted** via `deletedAt`. Hard-delete is blocked
/// by the `ON DELETE RESTRICT` FK from `PlatformAuditLog.operatorId` —
/// removing an operator who has audit-log entries would erase the
/// "who acted" pointer on those rows and defeat the table's purpose.
/// To decommission an operator: set `deletedAt = now()` and revoke
/// their `vectorflow_operator` Postgres role grants out of band.
model PlatformOperator {
  id        String               @id @default(cuid())
  email     String               @unique
  name      String
  role      PlatformOperatorRole @default(SUPPORT)
  /// Soft-delete timestamp. Once set, the operator's session is
  /// rejected at `requirePlatformOperator` and they are filtered out
  /// of the privileged-operator roster view. Audit-log entries remain.
  deletedAt DateTime?
  createdAt DateTime             @default(now())
  updatedAt DateTime             @updatedAt

  accessGrants         OrgAccessGrant[]
  platformAuditEntries PlatformAuditLog[]
  approvalsRequested   OperatorApprovalRequest[] @relation("OperatorApprovalRequester")
  approvalsApproved    OperatorApprovalRequest[] @relation("OperatorApprovalApprover")
  approvalsExecuted    OperatorApprovalRequest[] @relation("OperatorApprovalExecutor")
}

/// `OperatorApprovalRequest` — generic 2-person approval primitive for
/// privileged operator actions that require dual control. Examples: backup
/// restore, force hard-delete before grace expires, key rotation that
/// keeps prior versions.
///
/// The model is intentionally generic: each operation type is identified
/// by a free-form `operation` string and the consumer interprets
/// `payload` JSON to drive the actual side-effect.
///
/// State machine:
///   PENDING_APPROVAL → APPROVED → EXECUTING → COMPLETED | FAILED
///                ↘ CANCELLED   ↘ CANCELLED
///                ↘ EXPIRED
///
/// Two-person rule enforced at the service layer:
/// `approvedByOperatorId !== requestedByOperatorId`. Same-person
/// approval is a database-level violation (UNIQUE index on the pair
/// would not catch it; the check is in the service code).
///
/// `expiresAt` exists so a stale request can't be approved years
/// later. Default TTL is 24 hours; configurable per operation.
model OperatorApprovalRequest {
  id                    String            @id @default(cuid())
  /// Operation identifier. Free-form. Conventional values include
  /// "backup.restore", "tenant.hard_delete_force", "kms.rotate_keep".
  operation             String
  /// Free-form JSON payload interpreted by the operation handler.
  /// For "backup.restore", carries `{ recoveryPointArn: string }`.
  payload               Json
  /// Organization this action affects, when applicable. NULL for
  /// deployment-wide actions (KMS rotation, infra changes).
  organizationId        String?
  organization          Organization?     @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  /// Operator who requested the action.
  requestedByOperatorId String
  requestedByOperator   PlatformOperator  @relation("OperatorApprovalRequester", fields: [requestedByOperatorId], references: [id], onDelete: Cascade)
  /// Second operator who approved. NULL until approved. Service-layer
  /// invariant: MUST be different from requestedByOperatorId.
  approvedByOperatorId  String?
  approvedByOperator    PlatformOperator? @relation("OperatorApprovalApprover", fields: [approvedByOperatorId], references: [id], onDelete: SetNull)
  /// Free-text justification from the requester.
  reason                String
  /// Operator who executed the approved action. NULL until executed.
  executedByOperatorId  String?
  executedByOperator    PlatformOperator? @relation("OperatorApprovalExecutor", fields: [executedByOperatorId], references: [id], onDelete: SetNull)
  /// State machine status. See model docstring for transitions.
  status                String            @default("PENDING_APPROVAL")
  /// Failure reason if status=FAILED.
  failureReason         String?
  requestedAt           DateTime          @default(now())
  approvedAt            DateTime?
  executedAt            DateTime?
  completedAt           DateTime?
  /// Approval window. Past this, status is auto-flipped to EXPIRED
  /// by a cron sweep (or rejected at approve-time).
  expiresAt             DateTime

  @@index([status, expiresAt])
  @@index([organizationId])
  @@index([organizationId, status])
  @@index([operation])
  @@index([requestedByOperatorId])
}

// ─── End multi-tenancy models ───────────────────────────────────────────────
model User {
  id                       String               @id @default(cuid())
  email                    String               @unique
  name                     String?
  image                    String?
  passwordHash             String?
  authMethod               AuthMethod           @default(LOCAL)
  memberships              TeamMember[]
  orgMemberships           OrgMember[]
  scimGroupMemberships     ScimGroupMember[]
  accounts                 Account[]
  lockedAt                 DateTime?
  lockedBy                 String?
  mustChangePassword       Boolean              @default(false)
  totpSecret               String?
  totpEnabled              Boolean              @default(false)
  totpBackupCodes          String?
  /// Highest TOTP time-step already consumed for this user. A code whose
  /// absolute step is <= this value is rejected as a replay, making each
  /// TOTP code single-use within its validation window. Null until the
  /// first successful TOTP verification.
  lastTotpStep             Int?
  scimExternalId           String?              @unique
  auditLogs                AuditLog[]
  pipelinesUpdated         Pipeline[]           @relation("PipelineUpdatedBy")
  pipelinesCreated         Pipeline[]           @relation("PipelineCreatedBy")
  vrlSnippets              VrlSnippet[]
  dashboardViews           DashboardView[]
  serviceAccounts          ServiceAccount[]
  releasesRequested        Release[]            @relation("ReleaseRequestedBy")
  releasesReviewed         Release[]            @relation("ReleaseReviewedBy")
  releasesDeployed         Release[]            @relation("ReleaseDeployedBy")
  tapCaptures              TapCapture[]         @relation("TapCaptureCreatedBy")
  proposedChangesCreated   ProposedChange[]     @relation("ProposedChangeCreatedBy")
  proposedChangesReviewed  ProposedChange[]     @relation("ProposedChangeReviewedBy")
  replaysCreated           ReplayJob[]          @relation("ReplayCreatedBy")
  preferences              UserPreference[]
  aiConversationsCreated   AiConversation[]     @relation("AiConversationCreatedBy")
  aiMessagesCreated        AiMessage[]          @relation("AiMessageCreatedBy")
  pipelineVersionsCreated  PipelineVersion[]    @relation("PipelineVersionCreatedBy")
  filterPresets            FilterPreset[]
  migrationProjectsCreated MigrationProject[]   @relation("MigrationProjectCreatedBy")
  dismissedRecommendations CostRecommendation[] @relation("CostRecommendationDismissedBy")
  webauthnCredentials      WebAuthnCredential[]
  createdAt                DateTime             @default(now())
}

/// WebAuthn / passkey credential registered for a User.
///
/// Cross-org users carry one credential set per `User` — passkeys are
/// account-wide, not per-tenant. The relying-party identity is the platform
/// apex so a single passkey works across every org the user is a member
/// of. Per-org JWT signing keys still scope the resulting session to one org.
model WebAuthnCredential {
  id           String    @id @default(cuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// Base64url-encoded credential id returned by the authenticator. Unique
  /// across the whole platform so we can resolve a user from a bare
  /// `getAssertion()` response without first looking up the email.
  credentialId String    @unique
  /// Raw COSE-encoded public key bytes (Bytes, not bytea-encoded base64).
  publicKey    Bytes
  /// Authenticator signature counter. MUST be persisted and re-checked on
  /// every assertion to defeat token cloning / replay.
  counter      BigInt    @default(0)
  /// Transport hints (`usb`, `ble`, `nfc`, `internal`, `hybrid`). Stored so
  /// `allowCredentials` on subsequent authentications can include them
  /// without re-prompting the user.
  transports   String[]  @default([])
  /// `"singleDevice"` (hardware token tied to one device) or
  /// `"multiDevice"` (passkey synced via the platform — iCloud Keychain etc.).
  deviceType   String?
  /// True when the credential is backed up by the platform (synced).
  backedUp     Boolean   @default(false)
  /// User-supplied label, e.g. "YubiKey 5C" or "MacBook TouchID".
  name         String?
  createdAt    DateTime  @default(now())
  lastUsedAt   DateTime?

  @@index([userId])
}

/// Short-lived WebAuthn challenge issued during register / authenticate
/// option-generation. Stored in the DB (not a cookie) so the verifying
/// request can prove the challenge it received was the one we minted.
/// Rows MUST be expired aggressively — default 5 minutes is more than
/// enough for the platform/authenticator round trip.
model WebAuthnChallenge {
  id             String   @id @default(cuid())
  /// Tenant scope. The challenge bytes are themselves a
  /// 256-bit secret so cross-org enumeration is not feasible without
  /// guessing, but having the column lets the cleanup job filter by
  /// tenant and lets RLS fence direct reads end-to-end.
  organizationId String   @default("default")
  /// One of "register" or "authenticate".
  kind           String
  /// The challenge bytes, base64url-encoded.
  challenge      String   @unique
  /// Userid the challenge was minted for. Nullable because the
  /// authentication flow may begin without a known user (usernameless
  /// passkey UX).
  userId         String?
  expiresAt      DateTime
  createdAt      DateTime @default(now())

  @@index([expiresAt])
  @@index([userId])
  @@index([organizationId, expiresAt])
}

/// Magic-link sign-in token.
///
/// Persistent state for the magic-link sign-in flow: a hash of the
/// random token is stored, the email it was minted for, the org it
/// belongs to (so per-org rate limiting can decide what to allow), and a
/// short TTL. Single-use: `consumedAt` is set inside the verifying
/// transaction so a captured link cannot be redeemed twice.
///
/// The plaintext token is NEVER stored — only `tokenHash` (SHA-256 hex).
/// The plaintext is mailed to the user once; the verify endpoint hashes
/// the incoming token and compares against `tokenHash`.
model MagicLinkToken {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  /// Email address the link was minted for. Used to resolve the User on
  /// redeem (or to bootstrap a new User on first sign-in).
  email          String
  /// SHA-256 hex digest of the plaintext token. Plaintext is NEVER stored.
  tokenHash      String       @unique
  expiresAt      DateTime
  consumedAt     DateTime?
  /// IP that requested the link, for audit.
  requestIp      String?
  createdAt      DateTime     @default(now())

  @@index([organizationId, email])
  @@index([expiresAt])
}

/// `BillingProviderRef` is a generic mapping between an `Organization`
/// and an external billing provider's customer / subscription IDs. The
/// table is generic; any provider-specific webhook/metering handler is
/// the caller's responsibility.
///
/// The shape supports any provider that emits a stable
/// `(customerId, subscriptionItemId)` pair. The `provider` field is a
/// free-form lowercase string (e.g. "stripe", "paddle", "chargebee");
/// the consuming overlay decides which values are recognized.
///
/// Self-hosted deployments that do not wire a billing provider leave
/// this table empty; the engine is dormant when no rows exist.
model BillingProviderRef {
  id                         String       @id @default(cuid())
  organizationId             String
  organization               Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  /// Free-form provider identifier. Lowercase by convention (e.g.
  /// "stripe", "paddle"). No constraint enforced here.
  provider                   String
  /// External provider's stable customer id (e.g. Stripe `cus_…`).
  providerCustomerId         String
  /// External provider's subscription-item id used as the metering target
  /// (e.g. Stripe `si_…`). Optional because per-seat-only plans don't
  /// have a metered subscription item.
  providerSubscriptionItemId String?
  /// Free-form status string set by the provider's webhook (e.g.
  /// "active", "past_due", "canceled"). Engine treats only "active" as
  /// billable; everything else is a skip for metering.
  status                     String       @default("active")
  createdAt                  DateTime     @default(now())
  updatedAt                  DateTime     @updatedAt

  /// One row per (org, provider). Re-subscribing replaces the row via
  /// upsert; we don't keep history here (the provider has audit logs).
  @@unique([provider, organizationId])
  /// Reverse lookup by external customer id is the inbound-webhook path.
  @@unique([provider, providerCustomerId])
  @@index([organizationId])
  @@index([organizationId, provider])
}

model UserPreference {
  id             String @id @default(cuid())
  organizationId String @default("default")
  userId         String
  user           User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  key            String
  value          String

  @@unique([userId, key])
  @@index([userId])
  @@index([organizationId])
}

enum AuthMethod {
  LOCAL
  OIDC
  MAGIC_LINK
}

model Team {
  id                   String             @id @default(cuid())
  organizationId       String             @default("default")
  name                 String
  requireTwoFactor     Boolean            @default(false)
  defaultEnvironmentId String?
  defaultEnvironment   Environment?       @relation("teamDefault", fields: [defaultEnvironmentId], references: [id], onDelete: SetNull)
  members              TeamMember[]
  environments         Environment[]
  templates            Template[]
  vrlSnippets          VrlSnippet[]
  alertRules           AlertRule[]
  availableTags        Json?              @default("[]") // string[] of admin-defined compliance tags
  webhookEndpoints     WebhookEndpoint[]
  migrationProjects    MigrationProject[]

  // AI-powered suggestions configuration
  aiProvider String? // "openai" | "anthropic" | "custom"
  aiBaseUrl  String? // OpenAI-compatible API endpoint
  aiApiKey   String? // Encrypted via crypto.ts
  aiModel    String? // e.g. "gpt-4o", "claude-sonnet-4-20250514"
  aiEnabled  Boolean @default(false)

  costRecommendations CostRecommendation[]
  anomalyEvents       AnomalyEvent[]
  createdAt           DateTime             @default(now())

  @@index([organizationId])
}

model ScimGroup {
  id             String            @id @default(cuid())
  /// Tenant scope. SCIM groups are managed per-org so a SCIM token
  /// issued for org A cannot list or mutate groups belonging to org B
  organizationId String            @default("default")
  organization   Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  displayName    String
  externalId     String?
  members        ScimGroupMember[]
  createdAt      DateTime          @default(now())

  @@unique([organizationId, displayName])
  @@unique([organizationId, externalId])
  @@index([organizationId])
}

model ScimGroupMember {
  id          String    @id @default(cuid())
  scimGroupId String
  userId      String
  scimGroup   ScimGroup @relation(fields: [scimGroupId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())

  @@unique([scimGroupId, userId])
}

model TeamMember {
  id     String @id @default(cuid())
  userId String
  teamId String
  role   Role
  source String @default("manual")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  team   Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([userId, teamId])
}

enum Role {
  VIEWER
  EDITOR
  ADMIN
}

model Environment {
  id                    String                  @id @default(cuid())
  organizationId        String                  @default("default")
  name                  String
  isSystem              Boolean                 @default(false)
  teamId                String?
  team                  Team?                   @relation(fields: [teamId], references: [id])
  nodes                 VectorNode[]
  pipelines             Pipeline[]
  secrets               Secret[]
  certificates          Certificate[]
