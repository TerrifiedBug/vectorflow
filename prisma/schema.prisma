enum ReleaseStrategy {
  DIRECT
  PROMOTION
  CANARY
}

/// Unified release record. Subsumes the former DeployRequest (DIRECT),
/// PromotionRequest (PROMOTION) and StagedRollout (CANARY) models. The
/// `strategy` discriminator selects which facet fields are populated; `status`
/// holds the per-strategy state-machine value:
///   DIRECT:    PENDING | APPROVED | REJECTED | CANCELLED | DEPLOYED
///   PROMOTION: PENDING | APPROVED | DEPLOYED | REJECTED | CANCELLED | AWAITING_PR_MERGE | DEPLOYING
///   CANARY:    CANARY_DEPLOYED | HEALTH_CHECK | BROADENED | ROLLED_BACK
model Release {
  id             String          @id @default(cuid())
  organizationId String          @default("default")
  strategy       ReleaseStrategy
  status         String

  // Primary pipeline + environment. For PROMOTION this is the SOURCE side.
  pipelineId    String
  pipeline      Pipeline    @relation("ReleasePipeline", fields: [pipelineId], references: [id], onDelete: Cascade)
  environmentId String
  environment   Environment @relation("ReleaseEnvironment", fields: [environmentId], references: [id], onDelete: Cascade)

  changelog  String  @default("")
  reviewNote String?

  // Actors (unified across strategies).
  requestedById String?
  requestedBy   User?   @relation("ReleaseRequestedBy", fields: [requestedById], references: [id], onDelete: SetNull)
  reviewedById  String?
  reviewedBy    User?   @relation("ReleaseReviewedBy", fields: [reviewedById], references: [id], onDelete: SetNull)
  deployedById  String?
  deployedBy    User?   @relation("ReleaseDeployedBy", fields: [deployedById], references: [id], onDelete: SetNull)

  // ── DIRECT facet (was DeployRequest) ──
  configYaml   String?
  nodeSelector Json?

  // ── PROMOTION facet (was PromotionRequest) ──
  targetPipelineId     String?
  targetPipeline       Pipeline?    @relation("ReleaseTargetPipeline", fields: [targetPipelineId], references: [id], onDelete: SetNull)
  targetEnvironmentId  String?
  targetEnvironment    Environment? @relation("ReleaseTargetEnvironment", fields: [targetEnvironmentId], references: [id], onDelete: Cascade)
  targetPipelineName   String?
  nodesSnapshot        Json?
  edgesSnapshot        Json?
  globalConfigSnapshot Json?
  prUrl                String?
  prNumber             Int?

  // ── CANARY facet (was StagedRollout) ──
  canaryVersionId          String?
  canaryVersion            PipelineVersion? @relation("ReleaseCanaryVersion", fields: [canaryVersionId], references: [id], onDelete: Cascade)
  previousVersionId        String?
  previousVersion          PipelineVersion? @relation("ReleasePreviousVersion", fields: [previousVersionId], references: [id])
  canarySelector           Json?
  originalSelector         Json?
  canaryNodeIds            Json?
  remainingNodeIds         Json?
  healthCheckWindowMinutes Int?
  healthCheckExpiresAt     DateTime?
  broadenedAt              DateTime?
  rolledBackAt             DateTime?

  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  reviewedAt DateTime?
  deployedAt DateTime?

  @@index([organizationId, strategy, status])
  @@index([pipelineId, strategy, status])
  @@index([environmentId, status])
  @@index([targetEnvironmentId])
  @@index([status, healthCheckExpiresAt])
}

model GitSyncJob {
  id             String      @id @default(cuid())
  organizationId String      @default("default")
  environmentId  String
  environment    Environment @relation(fields: [environmentId], references: [id], onDelete: Cascade)
  pipelineId     String
  pipeline       Pipeline    @relation(fields: [pipelineId], references: [id], onDelete: Cascade)
  action         String // "commit" | "delete"
  configYaml     String? // The YAML content for commit actions
  commitMessage  String?
  authorName     String?
  authorEmail    String?
  attempts       Int         @default(0)
  maxAttempts    Int         @default(3)
  lastError      String?
  status         String      @default("pending") // "pending" | "completed" | "failed"
  nextRetryAt    DateTime?
  createdAt      DateTime    @default(now())
  completedAt    DateTime?

  @@index([status, nextRetryAt])
  @@index([environmentId])
  @@index([pipelineId])
  @@index([organizationId])
}

enum AlertMetric {
  // Infrastructure (threshold-based, per-node)
  node_unreachable
  cpu_usage
  memory_usage
  disk_usage
  error_rate
  discarded_rate
  pipeline_crashed

  // Pipeline-scoped SLI metrics (threshold-based, per-pipeline aggregate)
  // Evaluated by FleetAlertService against PipelineMetric rollups.
  latency_mean
  throughput_floor

  // Fleet-wide (threshold-based, per-environment)
  fleet_error_rate
  fleet_throughput_drop
  fleet_event_volume
  node_load_imbalance

  // Drift detection (threshold-based)
  version_drift
  config_drift

  // Events (fire on occurrence)
  deploy_requested
  deploy_completed
  deploy_rejected
  deploy_cancelled
  new_version_available
  scim_sync_failed
  backup_failed
  certificate_expiring
  node_joined
  node_left
  // Subscriptions can be created against this event verb in advance of
  // wiring it up.
  promotion_completed
  git_sync_failed
  cost_threshold_exceeded // fires when monthly cost exceeds costBudgetCents
  log_keyword
}

enum AlertCondition {
  gt
  lt
  eq
}

enum AlertStatus {
  firing
  resolved
  acknowledged
  dismissed
}

model AlertRule {
  id                    String             @id @default(cuid())
  organizationId        String             @default("default")
  name                  String
  description           String?
  enabled               Boolean            @default(true)
  environmentId         String
  environment           Environment        @relation(fields: [environmentId], references: [id], onDelete: Cascade)
  pipelineId            String?
  pipeline              Pipeline?          @relation(fields: [pipelineId], references: [id], onDelete: Cascade)
  teamId                String
  team                  Team               @relation(fields: [teamId], references: [id], onDelete: Cascade)
  metric                AlertMetric
  condition             AlertCondition?
  threshold             Float?
  durationSeconds       Int?
  severity              String             @default("warning")
  ownerHint             String             @default("platform-ops")
  suggestedAction       String             @default("Review the alert context, then inspect the affected pipeline, node, and recent deployment changes.")
  snoozedUntil          DateTime?
  cooldownMinutes       Int?
  keyword               String?
  keywordSeverityFilter LogLevel?
  keywordWindowMinutes  Int?
  events                AlertEvent[]
  channels              AlertRuleChannel[]
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt

  @@index([environmentId])
  @@index([teamId])
  @@index([organizationId])
}

model WebhookEndpoint {
  id              String                @id @default(cuid())
  organizationId  String                @default("default")
  teamId          String
  team            Team                  @relation(fields: [teamId], references: [id], onDelete: Cascade)
  name            String
  url             String
  eventTypes      AlertMetric[]
  encryptedSecret String?
  enabled         Boolean               @default(true)
  /// Timestamp of the most recent successful one-time confirmation. Until set, `deliverOutboundWebhook` short-circuits to
  /// a non-retryable failure. URL changes clear it; the owner re-confirms.
  confirmedAt     DateTime?
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
  deliveries      WebhookDelivery[]
  confirmations   WebhookConfirmation[]

  @@index([teamId])
  @@index([organizationId])
}

/// One-time confirmation token for a `WebhookEndpoint`. Created
/// when an endpoint is added or its URL changes, mailed to the org's
/// OWNER role. Consuming the token sets `WebhookEndpoint.confirmedAt`;
/// until then the endpoint cannot deliver.
///
/// Single-use is enforced via `consumedAt: null` predicate on the
/// updateMany at consume time — same race-safe pattern as MagicLinkToken.
/// Plaintext is never persisted; only the SHA-256 hex digest hits the DB.
model WebhookConfirmation {
  id                String          @id @default(cuid())
  organizationId    String
  organization      Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  webhookEndpointId String
  webhookEndpoint   WebhookEndpoint @relation(fields: [webhookEndpointId], references: [id], onDelete: Cascade)
  tokenHash         String          @unique
  expiresAt         DateTime
  consumedAt        DateTime?
  requestedById     String?
  createdAt         DateTime        @default(now())

  @@index([webhookEndpointId])
  @@index([organizationId, expiresAt])
}

model WebhookDelivery {
  id                String          @id @default(cuid())
  webhookEndpointId String
  webhookEndpoint   WebhookEndpoint @relation(fields: [webhookEndpointId], references: [id], onDelete: Cascade)
  eventType         AlertMetric
  msgId             String
  payload           Json
  status            String // 'pending' | 'success' | 'failed' | 'dead_letter'
  statusCode        Int?
  errorMessage      String?
  attemptNumber     Int             @default(1)
  nextRetryAt       DateTime?
  requestedAt       DateTime        @default(now())
  completedAt       DateTime?

  @@index([webhookEndpointId, requestedAt])
  @@index([status, nextRetryAt])
}

model AlertEvent {
  id                 String                 @id @default(cuid())
  alertRuleId        String
  alertRule          AlertRule              @relation(fields: [alertRuleId], references: [id], onDelete: Cascade)
  nodeId             String?
  node               VectorNode?            @relation(fields: [nodeId], references: [id], onDelete: SetNull)
  status             AlertStatus
  value              Float
  message            String?
  firedAt            DateTime               @default(now())
  resolvedAt         DateTime?
  notifiedAt         DateTime?
  acknowledgedAt     DateTime?
  acknowledgedBy     String?
  errorContext       Json? // { lines: Array<{timestamp, message}>, truncated }
  correlationGroupId String?
  correlationGroup   AlertCorrelationGroup? @relation(fields: [correlationGroupId], references: [id], onDelete: SetNull)
  deliveries         DeliveryAttempt[]

  @@index([alertRuleId])
  @@index([nodeId])
  @@index([firedAt])
  @@index([correlationGroupId])
}

model AlertCorrelationGroup {
  id                  String         @id @default(cuid())
  environmentId       String
  environment         Environment    @relation(fields: [environmentId], references: [id], onDelete: Cascade)
  status              AlertStatus    @default(firing)
  rootCauseEventId    String?
  rootCauseSuggestion String?
  eventCount          Int            @default(1)
  openedAt            DateTime       @default(now())
  closedAt            DateTime?
  events              AlertEvent[]
  anomalyEvents       AnomalyEvent[]

  @@index([environmentId, status])
  @@index([openedAt])
}

model DeliveryAttempt {
  id            String     @id @default(cuid())
  alertEventId  String
  alertEvent    AlertEvent @relation(fields: [alertEventId], references: [id], onDelete: Cascade)
  channelType   String // 'webhook' | 'slack' | 'email' | 'pagerduty'
  channelName   String
  status        String // 'pending' | 'success' | 'failed'
  statusCode    Int?
  errorMessage  String?
  attemptNumber Int        @default(1)
  nextRetryAt   DateTime?
  channelId     String?
  requestedAt   DateTime   @default(now())
  completedAt   DateTime?

  @@index([alertEventId])
  @@index([status, nextRetryAt])
}

model DashboardView {
  id             String   @id @default(cuid())
  organizationId String   @default("default")
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name           String
  panels         Json // string[] of panel names
  filters        Json? // { pipelineIds?: string[], nodeIds?: string[] }
  sortOrder      Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([userId])
  @@index([organizationId])
}

model NotificationChannel {
  id             String      @id @default(cuid())
  organizationId String      @default("default")
  environmentId  String
  environment    Environment @relation(fields: [environmentId], references: [id], onDelete: Cascade)
  name           String
  type           String // "slack" | "email" | "pagerduty" | "webhook"
  config         Json // Type-specific config
  enabled        Boolean     @default(true)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  alertRules AlertRuleChannel[]

  @@index([environmentId])
  @@index([organizationId])
}

model AlertRuleChannel {
  id          String              @id @default(cuid())
  alertRuleId String
  alertRule   AlertRule           @relation(fields: [alertRuleId], references: [id], onDelete: Cascade)
  channelId   String
  channel     NotificationChannel @relation(fields: [channelId], references: [id], onDelete: Cascade)

  @@unique([alertRuleId, channelId])
}

model ServiceAccount {
  id             String      @id @default(cuid())
  organizationId String      @default("default")
  name           String
  description    String?
  hashedKey      String      @unique
  keyPrefix      String
  environmentId  String
