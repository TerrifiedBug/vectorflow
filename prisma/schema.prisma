model AuditLog {
  id             String       @id @default(cuid())
  organizationId String       @default("default")
  userId         String?
  user           User?        @relation(fields: [userId], references: [id])
  action         String
  entityType     String
  entityId       String
  diff           Json?
  metadata       Json?
  ipAddress      String?
  userEmail      String?
  userName       String?
  teamId         String?
  environmentId  String?
  environment    Environment? @relation(fields: [environmentId], references: [id])
  createdAt      DateTime     @default(now())
  /**
   * Tamper-evidence chain.
   * `prevHash` is the previous row's `hash` (or `sha256("vf:audit-genesis:" || orgId)` for the first row).
   * `hash` is `sha256(prevHash || canonical(row))`.
   * NULL means the row pre-dates the chain rollout; `backfillChainForOrg`
   * walks NULL rows in `createdAt` order and fills them. NULL is treated
   * as "no tail" by `writeAuditLog`, so new inserts chain off the most
   * recent already-chained row (or genesis if none exists yet).
   */
  prevHash       String?
  hash           String?

  @@index([entityType, entityId])
  @@index([userId])
  @@index([createdAt])
  @@index([action])
  @@index([teamId])
  @@index([environmentId])
  @@index([organizationId])
}

/**
 * Idempotency ledger for inbound webhooks that redeliver on 5xx
 * (billing providers, git providers, PagerDuty, custom integrations).
 * The table is provider-agnostic: any handler that needs once-only
 * processing under 5xx-retry semantics inserts `(source, id)` here and
 * skips if the row already exists. `source` is a free-form lowercase
 * provider identifier; `id` is the provider-issued event id.
 * Self-hosted deployments that do not wire any webhook source leave
 * this table empty.
 */
model IdempotentInboundWebhookEvent {
  /**
   * Provider-issued event id. Combined with `source` as the composite
   * primary key to enforce per-source idempotency without cross-source
   * id-space collisions (e.g. a Stripe `evt_…` that coincidentally
   * matches a GitHub delivery UUID must be treated as two distinct
   * events). Callers read via `source_id: { source, id }` in Prisma.
   */
  id          String
  /**
   * Provider name. Lowercase, stable identifier of the webhook
   * source (e.g. "stripe", "github", "gitlab", "pagerduty"). Callers
   * MUST pass `source` explicitly; the previous back-compat default
   * was dropped once all writers were migrated.
   */
  source      String
  /**
   * Provider-issued event type (e.g. `customer.subscription.updated`,
   * `push`).
   */
  type        String
  /**
   * When the handler first observed and committed this event.
   */
  processedAt DateTime @default(now())

  @@id([source, id])
  @@index([processedAt])
  @@index([type])
  @@index([source])
  @@index([source, processedAt])
}

/**
 * Per-organization audit-chain tail pointer.
 * Single source of truth for "what is the most recently-chained AuditLog
 * row's hash for this org" — used by writeAuditLog to compute prevHash on
 * the next insert. Maintained inside the same advisory-locked transaction
 * as the AuditLog insert, so the lookup is atomic and immune to cross-
 * process / same-millisecond races that ID-based tail ordering cannot
 * defend against.
 */
model AuditChainTail {
  organizationId String   @id
  /**
   * Hash of the most recently chained AuditLog row for this org.
   */
  lastHash       String
  /**
   * When that row was written. Informational; not used for ordering.
   */
  lastWriteAt    DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

/**
 * Platform operator audit log.
 * Records every operator action that touches a customer org: break-glass
 * grant request/approval/use, suspend/unsuspend, backup restore,
 * deployment restart, key-unwrap during a grant window, etc. Lives in a separate
 * table from `AuditLog` so:
 * 1. The two streams have different retention / export policies.
 * `AuditLog` is customer-visible (per-org export endpoint);
 * `PlatformAuditLog` is operator-internal but mirrored into the
 * customer's `AuditLog` with a "support actor" label whenever an
 * action affects an org the customer can see.
 * 2. An external archiver sidecar can ship rows to a WORM-storage
 * bucket (e.g. S3 Object Lock) without involving the customer-
 * side `AuditLog` stream.
 * 3. RLS does not apply: this table is read only by the operator
 * Postgres role (separate from the app role).
 * Append-only enforced at three layers:
 * - No `updatedAt` field (rows are immutable by schema shape).
 * - Postgres rules in the migration prevent `UPDATE` and `DELETE`
 * against this table for the operator role; only the platform-audit
 * writer role can INSERT.
 * - The bundled verifier script walks the per-deployment hash chain
 * and refuses an export where any link is broken.
 * Hash chain (`prevHash`, `hash`) uses the same scheme as `AuditLog`
 * (sha256(prevHash || canonical(row))) but chains per-deployment rather
 * than per-org — the "key" passed to `AuditChainTailLookup.getTailHash`
 * is `platform-audit:<deploymentId>`. Genesis is
 * `sha256("vf:platform-audit-genesis:" || deploymentId)`.
 */
model PlatformAuditLog {
  id                String                @id @default(cuid())
  /**
   * Deployment identifier — distinguishes between multiple regional
   * deployments that share a global PlatformAuditLog warehouse (rare;
   * typically each deployment has its own DB). Defaults to "default"
   * for single-deployment installs.
   */
  deploymentId      String                @default("default")
  /**
   * The PlatformOperator who performed the action. NULL only for
   * system-initiated events (e.g. automated deployment restart from
   * a health check); always set for human-initiated actions.
   */
  operatorId        String?
  operator          PlatformOperator?     @relation(fields: [operatorId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  /**
   * Operator role at time of action ("SUPPORT", "INFRA", "BILLING",
   * "INCIDENT"). Cached on the row so a later role change doesn't
   * obscure the historical record.
   */
  operatorRole      PlatformOperatorRole?
  /**
   * Verb identifying the action. Stable identifier ("grant.request",
   * "grant.approve", "grant.use", "org.suspend", "backup.restore",
   * "deployment.restart", "kms.unwrap"). Kept as a free-text TEXT to avoid
   * coupling the audit log to an enum migration cadence.
   */
  action            String
  /**
   * Organization affected by the action, when applicable. NULL for
   * deployment-wide actions (deployment restart, KMS rotation, etc.). When set,
   * a mirror row is inserted into the customer's `AuditLog` with
   * `userName = "VectorFlow Support"`.
   */
  organizationId    String?
  /**
   * Free-text justification supplied by the operator (required for
   * break-glass actions; optional for routine ops). Stored verbatim
   * for post-incident review.
   */
  reason            String?
  /**
   * Entity acted on (table + id) for actions that have a definite
   * subject ("BackupRecord", "rec_abc123"). NULL for actions where
   * the subject is the org itself or the deployment.
   */
  entityType        String?
  entityId          String?
  /**
   * Structured action-specific context. e.g. `{ grantId: "...",
   * expiresAt: "..." }` for grant requests; `{ backupId: "...",
   * approvers: ["op_a", "op_b"] }` for backup restores. Subject to
   * the same canonicalization rules as `AuditLog.diff` so the hash
   * chain is reproducible.
   */
  metadata          Json?
  /**
   * Source IP of the operator session that performed the action.
   * Captured from the privileged-operator request handler.
   */
  ipAddress         String?
  createdAt         DateTime              @default(now())
  /**
   * Tamper-evidence chain — same primitive as `AuditLog.prevHash` /
   * `AuditLog.hash` (sha256(prevHash || canonical(row))), keyed per
   * deployment instead of per org.
   */
  prevHash          String
  hash              String
  /**
   * Audit object-store archive timestamp. NULL until an external
   * archiver sidecar successfully PUTs the row to its configured
   * object store. The archiver polls
   * `WHERE archivedAt IS NULL ORDER BY createdAt ASC` and stamps this
   * column on success.
   * Self-hosted installs that leave the archiver disabled keep this
   * column NULL everywhere; it costs nothing.
   */
  archivedAt        DateTime?
  /**
   * Object key (or equivalent identifier) returned by the archiver
   * sidecar on successful upload. Free-form text so the same column
   * works for S3 keys, GCS object paths, Azure blob names, etc.
   * NULL when `archivedAt` is NULL.
   */
  archivedObjectKey String?

  @@index([deploymentId, createdAt])
  @@index([operatorId])
  @@index([action])
  @@index([organizationId])
  @@index([organizationId, createdAt])
  @@index([createdAt])
  // Archiver poll query (`WHERE archivedAt IS NULL ORDER BY createdAt`).
  // The migration creates this as a PARTIAL index on `createdAt WHERE archivedAt IS NULL`
  // (see 20260517000006_platform_audit_archived). Prisma cannot express partial
  // index predicates in schema.prisma; we declare only the index column(s) with the
  // matching `map` name so Prisma recognises the index by name and does not generate
  // a follow-up migration that would replace the partial index with an unbounded one.
  @@index([createdAt], map: "PlatformAuditLog_archivedAt_createdAt_idx")
}

/**
 * Per-deployment PlatformAuditLog chain tail pointer. Mirrors the
 * per-org `AuditChainTail` for the customer-facing `AuditLog`.
 */
model PlatformAuditChainTail {
  deploymentId String   @id
  lastHash     String
  lastWriteAt  DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model SystemSettings {
