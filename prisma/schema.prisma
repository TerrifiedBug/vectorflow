// ─── Anomaly Detection ─────────────────────────────────────────────────────

enum AnomalyType {
  throughput_drop
  throughput_spike
  error_rate_spike
  latency_spike
}

enum AnomalySeverity {
  info // > 2 sigma
  warning // > 3 sigma
  critical // > 4 sigma
}

model AnomalyEvent {
  id                 String                 @id @default(cuid())
  organizationId     String                 @default("default")
  pipelineId         String
  pipeline           Pipeline               @relation(fields: [pipelineId], references: [id], onDelete: Cascade)
  environmentId      String
  environment        Environment            @relation(fields: [environmentId], references: [id], onDelete: Cascade)
  teamId             String
  team               Team                   @relation(fields: [teamId], references: [id], onDelete: Cascade)
  anomalyType        AnomalyType
  severity           AnomalySeverity
  metricName         String // "eventsIn" | "errorsTotal" | "latencyMeanMs"
  currentValue       Float
  baselineMean       Float
  baselineStddev     Float
  deviationFactor    Float // how many stddevs from baseline
  message            String
  status             String                 @default("open") // "open" | "acknowledged" | "dismissed"
  detectedAt         DateTime               @default(now())
  acknowledgedAt     DateTime?
  acknowledgedBy     String?
  dismissedAt        DateTime?
  dismissedBy        String?
  errorContext       Json? // { lines: Array<{timestamp, message}>, truncated }
  correlationGroupId String?
  correlationGroup   AlertCorrelationGroup? @relation(fields: [correlationGroupId], references: [id], onDelete: SetNull)
  createdAt          DateTime               @default(now())

  @@index([pipelineId])
  @@index([environmentId])
  @@index([teamId])
  @@index([status])
  @@index([detectedAt])
  @@index([correlationGroupId])
  @@index([organizationId])
}

/// Per-organisation price model for a destination (Vector sink type), used to
/// turn byte-volume estimates into projected dollar cost in analytics and cost
/// recommendations (B3).
model DestinationCostModel {
  id              String   @id @default(cuid())
  organizationId  String   @default("default")
  /// Vector sink component type, e.g. "datadog_logs", "splunk_hec",
  /// "elasticsearch", "aws_s3".
  sinkType        String
  /// Human label shown in the UI (defaults to the sink type).
  label           String?
  /// Destination price in cents per GB.
  pricePerGbCents Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([organizationId, sinkType])
  @@index([organizationId])
}

/// Downsampled NodeMetric rollup (hourly/daily) retained far longer than raw
/// metrics (B5). Gauge columns hold the bucket AVERAGE; max* columns hold the
/// bucket peak for the alerting-relevant gauges.
model NodeMetricRollup {
  id                 String     @id @default(cuid())
  organizationId     String     @default("default")
  nodeId             String
  node               VectorNode @relation(fields: [nodeId], references: [id], onDelete: Cascade)
  bucketStart        DateTime
  granularity        String
  sampleCount        Int        @default(0)
  memoryUsedBytes    BigInt     @default(0)
  memoryTotalBytes   BigInt     @default(0)
  cpuSecondsTotal    Float      @default(0)
  cpuSecondsIdle     Float      @default(0)
  loadAvg1           Float      @default(0)
  loadAvg5           Float      @default(0)
  loadAvg15          Float      @default(0)
  fsUsedBytes        BigInt     @default(0)
  fsTotalBytes       BigInt     @default(0)
  diskReadBytes      BigInt     @default(0)
  diskWrittenBytes   BigInt     @default(0)
  netRxBytes         BigInt     @default(0)
  netTxBytes         BigInt     @default(0)
  maxMemoryUsedBytes BigInt     @default(0)
  maxLoadAvg1        Float      @default(0)

  @@unique([nodeId, granularity, bucketStart])
  @@index([nodeId, granularity, bucketStart])
  @@index([organizationId, bucketStart])
}

/// Downsampled PipelineMetric rollup (B5). Counter columns hold the bucket SUM;
/// utilization/latency hold the bucket AVERAGE. componentId "" = pipeline
/// aggregate row (mirrors PipelineMetric's null-aggregate, but non-null so the
/// unique key dedupes aggregate rows on upsert).
model PipelineMetricRollup {
  id              String   @id @default(cuid())
  organizationId  String   @default("default")
  pipelineId      String
  pipeline        Pipeline @relation(fields: [pipelineId], references: [id], onDelete: Cascade)
  componentId     String   @default("")
  bucketStart     DateTime
  granularity     String
  sampleCount     Int      @default(0)
  eventsIn        BigInt   @default(0)
  eventsOut       BigInt   @default(0)
  eventsDiscarded BigInt   @default(0)
  errorsTotal     BigInt   @default(0)
  bytesIn         BigInt   @default(0)
  bytesOut        BigInt   @default(0)
  utilization     Float    @default(0)
  latencyMeanMs   Float?
  maxLatencyMs    Float?
  spansIn         BigInt   @default(0)
  spansOut        BigInt   @default(0)
  tracesIn        BigInt   @default(0)

  @@unique([pipelineId, componentId, granularity, bucketStart])
  @@index([pipelineId, granularity, bucketStart])
  @@index([organizationId, bucketStart])
}

/// A persisted live-tap capture (B4): a named snapshot of real events captured
/// from a pipeline component, retained beyond the ephemeral EventSample TTL so
/// it can be replayed through the transform-eval harness for iteration.
model TapCapture {
  id             String   @id @default(cuid())
  organizationId String   @default("default")
  pipelineId     String
  pipeline       Pipeline @relation(fields: [pipelineId], references: [id], onDelete: Cascade)
  name           String
  componentKey   String
  events         Json
  schema         Json
  eventCount     Int      @default(0)
  createdById    String?
  createdBy      User?    @relation("TapCaptureCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt      DateTime @default(now())

  @@index([organizationId, pipelineId])
  @@index([pipelineId])
}

/// IF-6: a saved VRL unit test — a named input→expected snippet pinned to a
/// pipeline transform component. The runner evaluates the editor's current VRL
/// source against `input` and asserts the single transformed output deep-equals
/// `expected`, so authors can capture regression cases for a remap/transform
/// before deploying. Org-scoped (RLS by organizationId) and pipeline-scoped.
model VrlUnitTest {
  id             String   @id @default(cuid())
  organizationId String   @default("default")
  pipelineId     String
  pipeline       Pipeline @relation(fields: [pipelineId], references: [id], onDelete: Cascade)
  componentKey   String
  name           String
  input          Json
  expected       Json
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([organizationId, pipelineId])
  @@index([pipelineId])
}

enum ProposedChangeKind {
  PIPELINE_GRAPH
  VRL
}

enum ProposedChangeStatus {
  PENDING
  APPROVED
  REJECTED
  APPLIED
}

/// A human-approval-gated change proposed by the agentic AI (B2). The AI
/// generates a pipeline-graph or VRL edit; the server validates it (vector
/// validate + VRL eval, with an auto-fix loop) and stages it here. An EDITOR
/// must approve before it is applied — autonomy is capped at human-approved apply.
model ProposedChange {
  id                   String               @id @default(cuid())
  organizationId       String               @default("default")
  pipelineId           String
  pipeline             Pipeline             @relation("ProposedChangePipeline", fields: [pipelineId], references: [id], onDelete: Cascade)
  kind                 ProposedChangeKind
  status               ProposedChangeStatus @default(PENDING)
  summary              String               @db.Text
  prompt               String?              @db.Text
  proposedNodes        Json?
  proposedEdges        Json?
  proposedGlobalConfig Json?
  vrlSource            String?              @db.Text
  targetComponentKey   String?
  validationResult     Json?
  validated            Boolean              @default(false)
  createdById          String?
  createdBy            User?                @relation("ProposedChangeCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  reviewedById         String?
  reviewedBy           User?                @relation("ProposedChangeReviewedBy", fields: [reviewedById], references: [id], onDelete: SetNull)
  reviewNote           String?
  createdAt            DateTime             @default(now())
  reviewedAt           DateTime?
  appliedAt            DateTime?

  @@index([organizationId, status])
  @@index([pipelineId, status])
}

/// Retention/tiering policy for lake datasets (A1). hotDays = days kept in the
/// ClickHouse MergeTree hot tier before TTL-move to the S3-backed cold disk;
/// coldDays = total retention before TTL-delete.
model LakeRetentionPolicy {
  id             String        @id @default(cuid())
  organizationId String        @default("default")
  name           String
  hotDays        Int           @default(7)
  coldDays       Int           @default(90)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  datasets       LakeDataset[]

  @@unique([organizationId, name])
  @@index([organizationId])
}

/// Catalog metadata for a pipeline/environment's events stored in the lake
/// (ClickHouse). The events live in ClickHouse `lake_events`; this Postgres row
/// tracks the discovered schema, row/byte counts, time range and tiering so the
/// search UI and ops can reason about a dataset without querying ClickHouse.
model LakeDataset {
  id                String               @id @default(cuid())
  organizationId    String               @default("default")
  pipelineId        String
  pipeline          Pipeline             @relation("LakeDatasetPipeline", fields: [pipelineId], references: [id], onDelete: Cascade)
  environmentId     String
  environment       Environment          @relation("LakeDatasetEnvironment", fields: [environmentId], references: [id], onDelete: Cascade)
  schemaJson        Json?
  rowCount          BigInt               @default(0)
  byteCount         BigInt               @default(0)
  firstEventAt      DateTime?
  lastEventAt       DateTime?
  /// hot | cold | external (BYO bucket, cold-only — no in-place search).
  tiering           String               @default("hot")
  retentionPolicyId String?
  retentionPolicy   LakeRetentionPolicy? @relation(fields: [retentionPolicyId], references: [id], onDelete: SetNull)
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt

  @@unique([organizationId, pipelineId])
  @@index([organizationId])
  @@index([pipelineId])
}

/// A lake replay/rehydration job (A4): SELECTs stored events from the lake over
/// a time window and re-injects them into a target pipeline. Driven by the
/// control plane; the agent pulls bounded replay batches from /api/agent/replay.
model ReplayJob {
  id               String    @id @default(cuid())
  organizationId   String    @default("default")
  sourcePipelineId String
  sourcePipeline   Pipeline  @relation("ReplaySourcePipeline", fields: [sourcePipelineId], references: [id], onDelete: Cascade)
  targetPipelineId String
  targetPipeline   Pipeline  @relation("ReplayTargetPipeline", fields: [targetPipelineId], references: [id], onDelete: Cascade)
  fromTime         DateTime
  toTime           DateTime
  /// Optional event filter (eventType, free-text query) applied to the lake read.
  filter           Json?
  /// PENDING | RUNNING | COMPLETED | FAILED | CANCELLED
  status           String    @default("PENDING")
  totalEvents      BigInt    @default(0)
  replayedEvents   BigInt    @default(0)
  /// Idempotency / dedupe key stamped onto replayed events so re-injection is
  /// distinguishable and a re-run does not double-inject.
  dedupeKey        String
  error            String?
  createdById      String?
  createdBy        User?     @relation("ReplayCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  startedAt        DateTime?
  completedAt      DateTime?

  @@index([organizationId, status])
  @@index([targetPipelineId, status])
  @@index([status])
}

/// Per-environment "bring your own" object-storage bucket for the lake cold tier
/// (A5). When set, cold-tier writes target the customer's bucket; credentials are
/// encrypted at rest (crypto-v3). A dataset backed only by an external bucket is
/// marked LakeDataset.tiering = 'external' (no in-place ClickHouse search).
model EnvironmentLakeBucket {
  id                       String      @id @default(cuid())
  organizationId           String      @default("default")
  environmentId            String      @unique
  environment              Environment @relation(fields: [environmentId], references: [id], onDelete: Cascade)
  /// "s3" | "gcs" | "azure"
  provider                 String
  bucket                   String
  region                   String?
  endpoint                 String?
  prefix                   String?
  /// crypto-v3 encrypted credentials (null when using instance/workload identity).
  encryptedAccessKeyId     String?
  encryptedSecretAccessKey String?
  createdAt                DateTime    @default(now())
  updatedAt                DateTime    @updatedAt

  @@index([organizationId, environmentId])
}

/// A scheduled threshold alert over a Lake dataset (A6). A saved summarize/
/// search spec runs on a cadence (`intervalSeconds`); when the aggregate value
/// crosses `threshold` the rule fires (edge-triggered) via a notification
/// channel. Firing state lives on the row — no separate history table in v1.
model LakeAlertRule {
  id              String    @id @default(cuid())
  organizationId  String    @default("default")
  pipelineId      String
  pipeline        Pipeline  @relation("LakeAlertRulePipeline", fields: [pipelineId], references: [id], onDelete: Cascade)
  /// Denormalized from the pipeline; scopes channel dispatch + the UI channel picker.
  environmentId   String
  name            String
  /// Saved query spec: { eventType?, query?, groupBy?, metric, metricField?, windowSeconds }.
  spec            Json
  /// GT | GTE | LT | LTE
  comparator      String
  threshold       Float
  intervalSeconds Int       @default(300)
  /// Optional NotificationChannel id to dispatch to (null = evaluate only, no delivery).
  channelId       String?
  enabled         Boolean   @default(true)
  lastEvaluatedAt DateTime?
  lastFiredAt     DateTime?
  lastValue       Float?
  firing          Boolean   @default(false)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([organizationId, enabled, lastEvaluatedAt])
  @@index([pipelineId])
}
