# ── Required ──────────────────────────────────────────────────

# VectorFlow server URL
VF_URL=https://your-vectorflow-instance:3000

# Enrollment token (generate in VectorFlow UI: Environment > Agent Enrollment)
# Only needed for first enrollment — after that the agent uses its persisted node token.
VF_TOKEN=<enrollment-token-from-ui>

# ── Optional ──────────────────────────────────────────────────

# How often the agent polls before server fleet settings load (Go duration format: 5s, 1m, etc.)
#VF_POLL_INTERVAL=5s

# How often the agent flushes buffered logs to the server (Go duration format).
#VF_LOG_FLUSH_INTERVAL=2s

# Log verbosity: debug, info, warn, error
#VF_LOG_LEVEL=info

# Directory for agent state (node token, pipeline configs, certs).
# Mapped to a Docker volume by default — don't change unless you know what you're doing.
#VF_DATA_DIR=/var/lib/vf-agent

# Path to the Vector binary. Set automatically in the Docker image.
#VF_VECTOR_BIN=/usr/local/bin/vector

# Node labels sent to VectorFlow on enrollment and every heartbeat.
# Format: comma-separated key=value pairs.
# Auto-detected labels (vf.io/* prefix) are always included regardless of this setting.
#VF_NODE_LABELS=region=us-east,role=web,env=prod
