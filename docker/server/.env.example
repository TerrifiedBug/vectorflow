# ── Required ──────────────────────────────────────────────────

# Database password for the TimescaleDB/PostgreSQL Compose service.
# Use a random 32+ character string. The container entrypoint percent-encodes
# this when constructing DATABASE_URL, so any printable characters are safe.
# Generate with: openssl rand -base64 32
POSTGRES_PASSWORD=change-me-to-a-random-32-char-string

# Secret used to sign NextAuth sessions and to derive the initial encryption key.
# Use a random 32+ character string. Generate with: openssl rand -base64 32
#
# ⚠️  If VF_ENCRYPTION_KEY_V2 (below) is NOT set, this value also derives the
#     encryption-at-rest master key. In that case do NOT rotate NEXTAUTH_SECRET —
#     doing so makes every encrypted secret (DB creds, OIDC/git/AI keys, TOTP)
#     permanently unrecoverable. To prevent that footgun, production REFUSES TO
#     BOOT unless you either set VF_ENCRYPTION_KEY_V2 (below) or explicitly accept
#     the coupling with VF_ALLOW_NEXTAUTH_DERIVED_KEY=true.
NEXTAUTH_SECRET=change-me-to-a-random-32-char-string

# (Required in production unless VF_ALLOW_NEXTAUTH_DERIVED_KEY=true.) Dedicated
# encryption key, decoupled from the session secret. When set, new encryptions
# use HKDF(VF_ENCRYPTION_KEY_V2) instead of NEXTAUTH_SECRET, so NEXTAUTH_SECRET
# can be rotated safely.
# Rotation procedure:
#   1. Generate: openssl rand -base64 32
#   2. Set this variable and deploy
#   3. Run the migration: pnpm tsx scripts/migrate-encryption.ts --dry-run
#                         pnpm tsx scripts/migrate-encryption.ts
#   4. After migration, NEXTAUTH_SECRET is still required for session signing
#      but is no longer used for data encryption.
#VF_ENCRYPTION_KEY_V2=change-me-to-a-different-random-32-char-string

# (Existing deployments only) Explicitly accept deriving the encryption-at-rest
# key from NEXTAUTH_SECRET when VF_ENCRYPTION_KEY_V2 is unset. Set to "true" to
# let production boot without a dedicated key. The coupling above still applies —
# never rotate NEXTAUTH_SECRET while this is set. Prefer migrating instead by
# setting VF_ENCRYPTION_KEY_V2 to your current NEXTAUTH_SECRET value.
#VF_ALLOW_NEXTAUTH_DERIVED_KEY=false

# ── Required ──────────────────────────────────────────────────

# The externally reachable URL of this deployment — used by NextAuth callbacks
# and any link rendered in alerts/dashboards/emails. Leave this commented to
# let NextAuth infer the host from incoming requests; set it explicitly for
# stable external links, OAuth callbacks, and non-local deployments.
#
# Local dev (optional): NEXTAUTH_URL=http://localhost:3000
# Production: NEXTAUTH_URL=https://vectorflow.example.com
#NEXTAUTH_URL=

# Reverse proxy + HTTPS: when VectorFlow runs behind a TLS-terminating proxy,
# NextAuth must know the external scheme is HTTPS so it issues secure
# (`__Secure-`) session cookies. Otherwise the cookie the browser stores and
# the one the server looks for diverge, and sign-in bounces straight back to
# /login (a redirect loop). Ensure the proxy forwards `X-Forwarded-Proto: https`
# (and `Host`), and/or set NEXTAUTH_URL to the https:// URL above.
#
# AUTH_TRUST_HOST=true is what tells NextAuth to trust those forwarded headers
# when NEXTAUTH_URL is unset. The bundled docker-compose files already set it;
# if you run the server image WITHOUT them, set AUTH_TRUST_HOST=true yourself.

# ── Optional ──────────────────────────────────────────────────

# Server port (default: 3000)
#PORT=3000

# Node environment (default: production in Docker)
#NODE_ENV=production

# Trust X-Forwarded-For/X-Real-IP only when VectorFlow is behind a trusted
# reverse proxy or ingress that overwrites client-supplied forwarded headers.
# This is used for IP-keyed API rate limits.
#VF_TRUST_PROXY_HEADERS=false

# (Optional) Connect to an external PostgreSQL instead of the bundled service.
# When set, this overrides the URL the entrypoint would otherwise build from
# POSTGRES_PASSWORD. Percent-encode any reserved characters in the password
# yourself (e.g. `/` → `%2F`, `+` → `%2B`, `=` → `%3D`).
#DATABASE_URL=postgresql://user:password@host:5432/dbname

# Maximum database connection pool size (default: 50).
# Increase for deployments with many concurrent agent heartbeats.
#DATABASE_POOL_MAX=50

# Maximum concurrent SSE connections per server instance (default: 5000).
# Returns HTTP 503 when limit is reached. Scale horizontally if needed.
#SSE_MAX_CONNECTIONS=5000

# ── WebAuthn / Passkeys (Optional) ───────────────────────────
# Relying-Party ID for passkey (WebAuthn) sign-in. Set this to the bare
# external host of NEXTAUTH_URL — no scheme, no port (e.g. for
# https://vectorflow.example.com use `vectorflow.example.com`).
#
# Behaviour when UNSET:
#   - Development: falls back to `localhost` so passkeys work locally.
#   - Production (NODE_ENV=production): passkey login is DISABLED — the server
#     refuses the insecure localhost fallback. Password and OIDC/SSO sign-in
#     are UNAFFECTED. Set this only if you want passkey login.
#VF_WEBAUTHN_RP_ID=vectorflow.example.com

# Display name shown in the OS/browser passkey prompt (default: VectorFlow).
#VF_WEBAUTHN_RP_NAME=VectorFlow

# Comma-separated list of allowed origins for passkey ceremonies. Only needed
# for multi-subdomain deployments; single-domain setups are derived from
# VF_WEBAUTHN_RP_ID automatically (https://<rp_id> and http://<rp_id>).
#VF_WEBAUTHN_ORIGINS=https://vectorflow.example.com,https://*.example.com

# ── Agent ────────────────────────────────────────────────────
# Enrollment token for the bundled vf-agent service.
# Generate one in the VectorFlow UI: Environments → (your environment) → Agent Enrollment → Generate token.
VF_ENROLLMENT_TOKEN=your-enrollment-token-here

# ── TimescaleDB Metrics (Optional) ───────────────────────────
# The default Docker Compose stack runs timescale/timescaledb:latest-pg16.
# TimescaleDB is auto-detected. Set to "false" to force plain PostgreSQL mode.
#TIMESCALEDB_ENABLED=auto

# Hypertable chunk interval (PostgreSQL interval syntax). Default: 1 day.
#METRICS_CHUNK_INTERVAL=1 day

# Compress chunks older than this. Default: 24 hours.
#METRICS_COMPRESS_AFTER=24 hours

# ── VectorFlow Lake (Optional) ───────────────────────────────
# Long-retention event store for logs, metrics and traces, backed by ClickHouse
# (separate from the Postgres/TimescaleDB metrics store). DISABLED by default:
# leave VF_LAKE_CLICKHOUSE_URL unset and the lake is fully inert — the server
# never connects, and non-lake deployments are completely unaffected.
#
# To run the bundled ClickHouse locally, start the `lake` compose profile:
#   docker compose --profile lake up -d
# then create the schema (idempotent — safe to re-run):
#   VF_LAKE_CLICKHOUSE_URL=http://localhost:8123 pnpm tsx scripts/lake-migrate.ts
#
# ClickHouse connection — set the URL to enable the lake.
#VF_LAKE_CLICKHOUSE_URL=http://clickhouse:8123
# Database created/used for lake tables (default: vectorflow_lake).
#VF_LAKE_CLICKHOUSE_DATABASE=vectorflow_lake
# Optional credentials (blank uses the ClickHouse `default` user).
#VF_LAKE_CLICKHOUSE_USER=
#VF_LAKE_CLICKHOUSE_PASSWORD=
#
# Cold tier (optional). When VF_LAKE_S3_BUCKET is set, the migration runner
# applies a TTL that moves data older than the hot window (7d) to an S3-backed
# `cold` disk and DELETEs it after the cold window (90d), via the `vf_hot_cold`
# storage policy in docker/server/clickhouse/config.d/storage.xml. Without a
# bucket, lake_events is a plain hot-only MergeTree with a TTL-delete, so it runs
# on a vanilla ClickHouse with no S3 disk configured.
#VF_LAKE_S3_ENDPOINT=https://s3.us-east-1.amazonaws.com
#VF_LAKE_S3_BUCKET=my-vectorflow-lake
#VF_LAKE_S3_REGION=us-east-1
#VF_LAKE_S3_ACCESS_KEY_ID=
#VF_LAKE_S3_SECRET_ACCESS_KEY=
