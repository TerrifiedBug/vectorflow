# ── Required ──────────────────────────────────────────────────

# Database password for the TimescaleDB/PostgreSQL Compose service.
# Use a random 32+ character string.
POSTGRES_PASSWORD=change-me-to-a-random-32-char-string

# Secret used to sign NextAuth sessions and to derive the initial encryption key.
# Use a random 32+ character string. Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=change-me-to-a-random-32-char-string

# (Optional) Dedicated encryption key for rotating away from NEXTAUTH_SECRET.
# When set, new encryptions use HKDF(VF_ENCRYPTION_KEY_V2) instead of NEXTAUTH_SECRET.
# Rotation procedure:
#   1. Generate: openssl rand -base64 32
#   2. Set this variable and deploy
#   3. Run the migration: pnpm tsx scripts/migrate-encryption.ts --dry-run
#                         pnpm tsx scripts/migrate-encryption.ts
#   4. After migration, NEXTAUTH_SECRET is still required for session signing
#      but is no longer used for data encryption.
#VF_ENCRYPTION_KEY_V2=change-me-to-a-different-random-32-char-string

# ── Required ──────────────────────────────────────────────────

# The externally reachable URL of this deployment — used by NextAuth callbacks
# and any link rendered in alerts/dashboards/emails. There is intentionally NO
# default: leaving this commented (or unset) makes Compose refuse to start
# rather than silently boot with broken external URLs.
#
# Local dev: NEXTAUTH_URL=http://localhost:3000
# Production: NEXTAUTH_URL=https://vectorflow.example.com
#NEXTAUTH_URL=

# ── Optional ──────────────────────────────────────────────────

# Server port (default: 3000)
#PORT=3000

# Node environment (default: production in Docker)
#NODE_ENV=production

# Trust X-Forwarded-For/X-Real-IP only when VectorFlow is behind a trusted
# reverse proxy or ingress that overwrites client-supplied forwarded headers.
# This is used for IP-keyed API rate limits.
#VF_TRUST_PROXY_HEADERS=false

# Maximum database connection pool size (default: 50).
# Increase for deployments with many concurrent agent heartbeats.
#DATABASE_POOL_MAX=50

# Maximum concurrent SSE connections per server instance (default: 5000).
# Returns HTTP 503 when limit is reached. Scale horizontally if needed.
#SSE_MAX_CONNECTIONS=5000

# ── Agent (Optional — required only when using the opensearch profile) ────────
# Enrollment token for the bundled vf-agent service (opensearch Compose profile).
# Generate one in the VectorFlow UI: Settings → Agent Tokens → Generate Enrollment Token.
VF_ENROLLMENT_TOKEN=your-enrollment-token-here

# ── TimescaleDB Metrics (Optional) ───────────────────────────
# The default Docker Compose stack runs timescale/timescaledb:latest-pg16.
# TimescaleDB is auto-detected. Set to "false" to force plain PostgreSQL mode.
#TIMESCALEDB_ENABLED=auto

# Hypertable chunk interval (PostgreSQL interval syntax). Default: 1 day.
#METRICS_CHUNK_INTERVAL=1 day

# Compress chunks older than this. Default: 24 hours.
#METRICS_COMPRESS_AFTER=24 hours
