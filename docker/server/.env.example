# ── Required ──────────────────────────────────────────────────

# Database password for PostgreSQL. Use a random 32+ character string.
POSTGRES_PASSWORD=change-me-to-a-random-32-char-string

# Secret used to encrypt sessions and sensitive data (TOTP secrets, etc.).
# Use a random 32+ character string. Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=change-me-to-a-random-32-char-string

# ── Optional ──────────────────────────────────────────────────

# Set to your canonical URL in production (e.g., https://vectorflow.example.com)
# When unset, AUTH_TRUST_HOST=true infers the URL from the Host header.
#NEXTAUTH_URL=http://localhost:3000

# Server port (default: 3000)
#PORT=3000

# Node environment (default: production in Docker)
#NODE_ENV=production

# Maximum database connection pool size (default: 50).
# Increase for deployments with many concurrent agent heartbeats.
#DATABASE_POOL_MAX=50

# Maximum concurrent SSE connections per server instance (default: 5000).
# Returns HTTP 503 when limit is reached. Scale horizontally if needed.
#SSE_MAX_CONNECTIONS=5000
